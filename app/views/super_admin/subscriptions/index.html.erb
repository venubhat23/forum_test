<% content_for :title, "Subscriptions" %>

<div class="page-header">
  <h1 class="page-title h4">Subscriptions</h1>
  <p class="page-subtitle mb-0">Plan, trial, and renewal status for every forum.</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Trial</div>
        <div class="mini-stat-value text-info"><%= @trial_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Suspended</div>
        <div class="mini-stat-value text-danger"><%= @suspended_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-pause-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Renewing in 30 Days</div>
        <div class="mini-stat-value text-warning"><%= @renewals_soon %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-arrow-repeat"></i></div>
    </div>
  </div>
</div>

<%= form_with url: super_admin_subscriptions_path, method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ] ] + Forum.statuses.keys.map { |s| [ s.titleize, s ] }, params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", super_admin_subscriptions_path, class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Forum</th>
          <th>Plan</th>
          <th>Status</th>
          <th>Started</th>
          <th>Trial Ends</th>
          <th>Renews On</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @forums.each do |forum| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= forum.name.first.upcase %></span>
                <span class="fw-semibold"><%= link_to forum.name, super_admin_forum_path(forum) %></span>
              </div>
            </td>
            <td><span class="badge badge-plan-<%= forum.plan.key %>"><%= forum.plan.name %></span></td>
            <td><span class="badge badge-status-<%= forum.status %>"><%= forum.status.titleize %></span></td>
            <td><%= forum.started_at&.strftime("%d %b %Y") %></td>
            <td>
              <% if forum.trial_ends_at %>
                <%= forum.trial_ends_at.strftime("%d %b %Y") %>
                <span class="text-muted small">(<%= forum.trial_days_left %>d left)</span>
              <% else %>
                <span class="text-muted">&mdash;</span>
              <% end %>
            </td>
            <td>
              <% if forum.renews_on %>
                <%= forum.renews_on.strftime("%d %b %Y") %>
                <span class="text-muted small">(<%= forum.days_to_renewal %>d)</span>
              <% end %>
            </td>
            <td class="text-end">
              <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">Manage</button>
                <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 260px;">
                  <%= form_with url: extend_trial_super_admin_subscription_path(forum), method: :patch, local: true, class: "mb-3" do %>
                    <label class="form-label small">Extend trial by (days)</label>
                    <div class="input-group input-group-sm">
                      <%= number_field_tag :days, 7, class: "form-control", min: 1 %>
                      <%= submit_tag "Extend", class: "btn btn-outline-primary" %>
                    </div>
                  <% end %>
                  <%= form_with url: change_renewal_date_super_admin_subscription_path(forum), method: :patch, local: true do %>
                    <label class="form-label small">Set renewal date</label>
                    <div class="input-group input-group-sm">
                      <%= date_field_tag :renews_on, forum.renews_on, class: "form-control" %>
                      <%= submit_tag "Save", class: "btn btn-outline-primary" %>
                    </div>
                  <% end %>
                </div>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @forums.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">No forums yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
