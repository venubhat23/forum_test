<% content_for :title, "Business Models" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Business Models</h1>
    <p class="page-subtitle mb-0">Subscription plans available to forums.</p>
  </div>
  <%= link_to new_super_admin_plan_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Create Plan
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Plans</div>
        <div class="mini-stat-value text-primary"><%= @total_plans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-gem"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_plans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Archived</div>
        <div class="mini-stat-value text-danger"><%= @archived_plans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-archive"></i></div>
    </div>
  </div>
</div>

<%= form_with url: super_admin_plans_path, method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name...", style: "max-width: 260px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Active", "active" ], [ "Archived", "archived" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", super_admin_plans_path, class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Key</th>
          <th>Price</th>
          <th>Billing</th>
          <th>Member Limit</th>
          <th>Chapter Limit</th>
          <th>Status</th>
          <th>Forums</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @plans.each do |plan| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-gem"></i></span>
                <span class="fw-semibold"><%= plan.name %></span>
              </div>
            </td>
            <td><code><%= plan.key %></code></td>
            <td>&#8377;<%= number_with_delimiter(plan.price.to_i) %></td>
            <td><%= plan.billing_cycle.titleize %></td>
            <td><%= plan.unlimited_members? ? "Unlimited" : plan.member_limit %></td>
            <td><%= plan.unlimited_chapters? ? "Unlimited" : plan.chapter_limit %></td>
            <td>
              <% if plan.active? %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-secondary">Archived</span>
              <% end %>
            </td>
            <td><%= plan.forums.count %></td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <%= link_to edit_super_admin_plan_path(plan), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <% if plan.active? %>
                  <%= button_to archive_super_admin_plan_path(plan), method: :patch, class: "icon-btn icon-btn-danger", title: "Archive" do %>
                    <i class="bi bi-archive"></i>
                  <% end %>
                <% else %>
                  <%= button_to activate_super_admin_plan_path(plan), method: :patch, class: "icon-btn icon-btn-success", title: "Activate" do %>
                    <i class="bi bi-check-lg"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @plans.empty? %>
          <tr><td colspan="9" class="text-center text-muted py-4">No plans yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
