<% content_for :title, "Create Invoice" %>

<div class="page-header">
  <h1 class="page-title h4">Create Invoice</h1>
  <p class="page-subtitle mb-0">Pick a plan and billing month — the amount fills in automatically.</p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="card invoice-preview-card">
      <div class="invoice-preview-topbar"></div>
      <div class="card-body p-4">
        <%= form_with model: @invoice, url: super_admin_invoices_path, method: :post, local: true,
              data: { controller: "invoice-plan" } do |f| %>

          <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
              <%= f.label :forum_id, "Forum", class: "form-label" %>
              <%= f.collection_select :forum_id, @forums, :id, :name, { prompt: "Select a forum" }, class: "form-select", required: true %>
            </div>
            <div class="col-12 col-md-6">
              <%= f.label :plan_id, "Plan", class: "form-label" %>
              <%= f.select :plan_id,
                    options_for_select(@plans.map { |plan|
                      [ "#{plan.name} — #{number_to_currency(plan.price, unit: '₹', format: '%u%n')}/#{plan.billing_cycle}", plan.id,
                        { data: { price: plan.price, cycle: plan.billing_cycle } } ]
                    }, @invoice.plan_id),
                    { include_blank: "No plan (custom invoice)" },
                    class: "form-select",
                    data: { invoice_plan_target: "planSelect", action: "change->invoice-plan#sync" } %>
              <div class="form-text d-none" data-invoice-plan-target="planSummary"></div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
              <%= label_tag :billing_month, "Billing month", class: "form-label" %>
              <%= text_field_tag :billing_month, Date.current.strftime("%Y-%m"), type: "month",
                    class: "form-control", data: { invoice_plan_target: "monthField", action: "change->invoice-plan#sync" } %>
              <div class="form-text">Which month this invoice covers — used to auto-word the description.</div>
            </div>
            <div class="col-12 col-md-6">
              <%= f.label :amount, "Amount (INR)", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text">&#8377;</span>
                <%= f.number_field :amount, class: "form-control", step: "0.01", min: 0, required: true,
                      data: { invoice_plan_target: "amountField", action: "input->invoice-plan#markAmountTouched" } %>
              </div>
              <div class="form-text">Auto-filled from the selected plan — edit to override.</div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
              <%= f.label :due_date, class: "form-label" %>
              <%= f.date_field :due_date, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-md-6">
              <%= label_tag :coupon_code, "Coupon code (optional)", class: "form-label" %>
              <%= text_field_tag :coupon_code, nil, class: "form-control text-uppercase" %>
            </div>
          </div>

          <div class="mb-4">
            <%= f.label :description, class: "form-label" %>
            <%= f.text_area :description, class: "form-control", rows: 3,
                  data: { invoice_plan_target: "descriptionField", action: "input->invoice-plan#markDescriptionTouched" } %>
            <div class="form-text">Auto-worded from the plan and billing month — edit any time.</div>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Create Invoice", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", super_admin_invoices_path, class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
