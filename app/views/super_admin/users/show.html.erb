<% content_for :title, @user.email %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @user.display_name %></h1>
    <p class="page-subtitle mb-0"><%= @user.email %> &middot; <span class="badge bg-secondary"><%= @user.role.titleize %></span></p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Edit", edit_super_admin_user_path(@user), class: "btn btn-outline-secondary" %>
    <% if @user.suspended? %>
      <%= button_to "Reactivate", unsuspend_super_admin_user_path(@user), method: :patch, class: "btn btn-success" %>
    <% else %>
      <%= button_to "Suspend", suspend_super_admin_user_path(@user), method: :patch, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Suspend #{@user.email}? They will be signed out and unable to log back in until reactivated." } %>
    <% end %>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="stats-card">
      <div class="icon-bg gradient-purple"><i class="bi bi-shield-lock"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @user.role.titleize %></div>
        <div class="stats-label">Role</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="stats-card">
      <div class="icon-bg gradient-green"><i class="bi bi-calendar3"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @user.created_at.strftime("%d %b %Y") %></div>
        <div class="stats-label">Joined</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header fw-semibold">Account Actions</div>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= button_to "Reset Password", reset_password_super_admin_user_path(@user), method: :post, class: "btn btn-outline-warning",
          data: { turbo_confirm: "Generate a new password for #{@user.email}?" } %>
    <%= button_to "Force Logout", force_logout_super_admin_user_path(@user), method: :post, class: "btn btn-outline-danger",
          data: { turbo_confirm: "Sign #{@user.email} out of all active sessions?" } %>
    <% unless @user == current_user %>
      <%= button_to "Delete User", super_admin_user_path(@user), method: :delete, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Permanently delete #{@user.email}? This cannot be undone." } %>
    <% end %>
  </div>
</div>
