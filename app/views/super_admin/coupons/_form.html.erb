<%= form_with model: coupon, url: url, method: method, local: true do |f| %>
  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6">
      <%= f.label :code, class: "form-label" %>
      <%= f.text_field :code, class: "form-control text-uppercase", required: true %>
    </div>
    <div class="col-12 col-md-6">
      <%= f.label :discount_type, class: "form-label" %>
      <%= f.select :discount_type, Coupon.discount_types.keys.map { |k| [ k.titleize, k ] }, {}, class: "form-select" %>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-md-4">
      <%= f.label :discount_value, "Discount value (% or &#8377;)".html_safe, class: "form-label" %>
      <%= f.number_field :discount_value, class: "form-control", step: "0.01", min: 0, required: true %>
    </div>
    <div class="col-12 col-md-4">
      <%= f.label :expires_on, "Expires on (blank = never)", class: "form-label" %>
      <%= f.date_field :expires_on, class: "form-control" %>
    </div>
    <div class="col-12 col-md-4">
      <%= f.label :max_redemptions, "Max redemptions (blank = unlimited)", class: "form-label" %>
      <%= f.number_field :max_redemptions, class: "form-control", min: 1 %>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", super_admin_coupons_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
