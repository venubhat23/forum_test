<% content_for :title, "Edit Coupon #{@coupon.code}" %>

<div class="page-header">
  <h1 class="page-title h4">Edit Coupon <%= @coupon.code %></h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", coupon: @coupon, url: super_admin_coupon_path(@coupon), method: :patch %>
      </div>
    </div>
  </div>
</div>
