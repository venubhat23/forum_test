<% content_for :title, "Coupons" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Coupons</h1>
    <p class="page-subtitle mb-0">Discount codes applicable to invoices.</p>
  </div>
  <%= link_to new_super_admin_coupon_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Create Coupon
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Coupons</div>
        <div class="mini-stat-value text-primary"><%= @total_coupons %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-tag"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_coupons %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Inactive</div>
        <div class="mini-stat-value text-danger"><%= @inactive_coupons %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-slash-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: super_admin_coupons_path, method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by code...", style: "max-width: 260px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Active", "active" ], [ "Inactive", "inactive" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", super_admin_coupons_path, class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Code</th>
          <th>Discount</th>
          <th>Expires</th>
          <th>Redemptions</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @coupons.each do |coupon| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-tag"></i></span>
                <code class="fw-semibold"><%= coupon.code %></code>
              </div>
            </td>
            <td><%= coupon.percentage? ? "#{coupon.discount_value.to_i}%" : "&#8377;#{number_with_delimiter(coupon.discount_value.to_i)}".html_safe %></td>
            <td><%= coupon.expires_on&.strftime("%d %b %Y") || "Never" %></td>
            <td><%= coupon.times_redeemed %><%= "/#{coupon.max_redemptions}" if coupon.max_redemptions %></td>
            <td>
              <% if coupon.active? %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-secondary">Inactive</span>
              <% end %>
            </td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <%= link_to edit_super_admin_coupon_path(coupon), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <% if coupon.active? %>
                  <%= button_to archive_super_admin_coupon_path(coupon), method: :patch, class: "icon-btn icon-btn-danger", title: "Deactivate" do %>
                    <i class="bi bi-slash-circle"></i>
                  <% end %>
                <% else %>
                  <%= button_to activate_super_admin_coupon_path(coupon), method: :patch, class: "icon-btn icon-btn-success", title: "Activate" do %>
                    <i class="bi bi-check-lg"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @coupons.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No coupons yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
