<% content_for :title, "Analytics" %>

<div class="page-header">
  <h1 class="page-title h4">Analytics</h1>
  <p class="page-subtitle mb-0">Trends across the last 6 months.</p>
</div>

<div class="row g-3">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Forums Created</div>
      <div class="card-body">
        <%= line_chart @forums_by_month %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Revenue Collected</div>
      <div class="card-body">
        <%= column_chart @revenue_by_month %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Attendance</div>
      <div class="card-body">
        <%= line_chart @attendance_by_month %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Referrals</div>
      <div class="card-body">
        <%= line_chart @referrals_by_month %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Plan Distribution</div>
      <div class="card-body">
        <%= pie_chart @plan_distribution %>
      </div>
    </div>
  </div>
</div>
