<% content_for :title, "Announcements" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Announcements</h1>
    <p class="page-subtitle mb-0">Broadcast messages to forums.</p>
  </div>
  <%= link_to new_super_admin_announcement_path, class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> New Announcement
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Audience</th>
          <th>Status</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @announcements.each do |a| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-megaphone"></i></span>
                <span class="fw-semibold"><%= a.title %></span>
              </div>
            </td>
            <td>
              <% case a.audience
                 when "everyone" %>All Forums
              <% when "specific_forum" %><%= a.forum&.name %>
              <% else %><%= a.plan&.name %> plan
              <% end %>
            </td>
            <td>
              <% if a.published? %>
                <span class="badge bg-success">Published</span>
              <% else %>
                <span class="badge bg-secondary">Draft</span>
              <% end %>
            </td>
            <td><%= a.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <%= link_to edit_super_admin_announcement_path(a), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <% unless a.published? %>
                  <%= button_to publish_super_admin_announcement_path(a), method: :patch, class: "icon-btn icon-btn-success", title: "Publish" do %>
                    <i class="bi bi-send"></i>
                  <% end %>
                <% end %>
                <%= button_to super_admin_announcement_path(a), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                      data: { turbo_confirm: "Delete this announcement?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @announcements.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No announcements yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
