<%= form_with model: announcement, url: url, method: method, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :body, class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: 4, required: true %>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
      <%= f.label :audience, class: "form-label" %>
      <%= f.select :audience, Announcement.audiences.keys.map { |a| [ a.titleize, a ] }, {}, class: "form-select" %>
    </div>
    <div class="col-12 col-md-4">
      <%= f.label :forum_id, "Forum (if Specific Forum)", class: "form-label" %>
      <%= f.collection_select :forum_id, @forums, :id, :name, { include_blank: true }, class: "form-select" %>
    </div>
    <div class="col-12 col-md-4">
      <%= f.label :plan_id, "Plan (if Specific Plan)", class: "form-label" %>
      <%= f.collection_select :plan_id, @plans, :id, :name, { include_blank: true }, class: "form-select" %>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", super_admin_announcements_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
