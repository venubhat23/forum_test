<% content_for :title, "Forum Requests" %>

<div class="page-header">
  <h1 class="page-title h4">Forum Requests</h1>
  <p class="page-subtitle mb-0">Inbound requests from prospects wanting to start a forum.</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Pending</div>
        <div class="mini-stat-value text-warning"><%= @pending_requests %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Approved</div>
        <div class="mini-stat-value text-success"><%= @approved_requests %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Rejected</div>
        <div class="mini-stat-value text-danger"><%= @rejected_requests %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-x-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: super_admin_forum_requests_path, method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Pending", "pending" ], [ "Approved", "approved" ], [ "Rejected", "rejected" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", super_admin_forum_requests_path, class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Organization</th>
          <th>Contact</th>
          <th>Email</th>
          <th>Status</th>
          <th>Submitted</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @forum_requests.each do |req| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= req.company_name.first.upcase %></span>
                <span class="fw-semibold"><%= req.company_name %></span>
              </div>
            </td>
            <td><%= req.name %></td>
            <td><%= req.email %></td>
            <td>
              <% case req.status
                 when "pending" %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% when "approved" %>
                <span class="badge bg-success">Approved</span>
              <% else %>
                <span class="badge bg-secondary">Rejected</span>
              <% end %>
            </td>
            <td><%= req.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to super_admin_forum_request_path(req), class: "icon-btn icon-btn-view", title: "Review" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @forum_requests.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No requests yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
