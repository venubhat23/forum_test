<% content_for :title, @forum.name %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @forum.name %></h1>
    <p class="page-subtitle mb-0">/f/<%= @forum.slug %></p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Edit", edit_super_admin_forum_path(@forum), class: "btn btn-outline-secondary" %>
    <% if @forum.suspended? %>
      <%= button_to "Activate", activate_super_admin_forum_path(@forum), method: :patch, class: "btn btn-success" %>
    <% else %>
      <%= button_to "Suspend", suspend_super_admin_forum_path(@forum), method: :patch, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Suspend #{@forum.name}? Its admin and members won't be able to access it." } %>
    <% end %>
    <% unless @forum.archived? %>
      <%= button_to "Archive", super_admin_forum_path(@forum), method: :delete, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Archive #{@forum.name}? It will be hidden from active use but its data is kept." } %>
    <% end %>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-blue"><i class="bi bi-diagram-3"></i></div>
      <div>
        <div class="stats-value"><%= @forum.chapters.count %></div>
        <div class="stats-label">Chapters</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-green"><i class="bi bi-people"></i></div>
      <div>
        <div class="stats-value"><%= @forum.users.member.count %><%= "/#{@forum.member_limit}" if @forum.member_limit %></div>
        <div class="stats-label">Members</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-purple"><i class="bi bi-shield-check"></i></div>
      <div>
        <div class="stats-value"><span class="badge badge-status-<%= @forum.status %>"><%= @forum.status.titleize %></span></div>
        <div class="stats-label">Status</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-indigo"><i class="bi bi-calendar3"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @forum.created_at.strftime("%d %b %Y") %></div>
        <div class="stats-label">Created</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header fw-semibold">Forum Admin</div>
  <div class="card-body">
    <% if @forum.admin %>
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
          <div class="sidebar-brand-icon"><i class="bi bi-person-fill"></i></div>
          <div>
            <div class="fw-semibold"><%= @forum.admin.email %></div>
            <div class="text-muted small">Forum Admin &middot; logs in at <code>/f/<%= @forum.slug %>/dashboard</code></div>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <%= button_to "Login as Admin", impersonate_super_admin_forum_path(@forum), method: :post, class: "btn btn-sm btn-outline-primary" %>
          <%= button_to "Reset Password", reset_admin_password_super_admin_forum_path(@forum), method: :post, class: "btn btn-sm btn-outline-warning",
                data: { turbo_confirm: "Generate a new password for #{@forum.admin.email}?" } %>
          <%= button_to "Force Logout", force_logout_admin_super_admin_forum_path(@forum), method: :post, class: "btn btn-sm btn-outline-danger",
                data: { turbo_confirm: "Sign #{@forum.admin.email} out of all active sessions?" } %>
        </div>
      </div>
    <% else %>
      <p class="text-muted mb-0">No admin assigned.</p>
    <% end %>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header fw-semibold">Subscription Plan</div>
  <div class="card-body">
    <div class="row g-3">
      <% Plan.ordered.active.each do |plan| %>
        <div class="col-12 col-md-4">
          <div class="card h-100 p-3 <%= "border-primary" if @forum.plan_id == plan.id %>">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="fw-semibold"><%= plan.name %></span>
              <% if @forum.plan_id == plan.id %>
                <span class="badge bg-primary">Current</span>
              <% end %>
            </div>
            <ul class="list-unstyled small text-muted mb-3">
              <% plan.features.each do |feature| %>
                <li><i class="bi bi-check2 text-success me-1"></i><%= feature %></li>
              <% end %>
            </ul>
            <% unless @forum.plan_id == plan.id %>
              <%= button_to "Switch to #{plan.name}", update_plan_super_admin_forum_path(@forum), params: { plan_id: plan.id }, method: :patch, class: "btn btn-sm btn-outline-primary mt-auto" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
