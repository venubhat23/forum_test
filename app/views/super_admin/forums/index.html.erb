<% content_for :title, "Forums" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Forum Management</h1>
    <p class="page-subtitle mb-0">All networking forums on the platform.</p>
  </div>
  <%= link_to new_super_admin_forum_path, class: "btn btn-primary rounded-pill px-4" do %>
    <i class="bi bi-plus-lg me-1"></i> Create Forum
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Forums</div>
        <div class="mini-stat-value text-primary"><%= @total_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-building"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Trial</div>
        <div class="mini-stat-value text-info"><%= @trial_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Suspended</div>
        <div class="mini-stat-value text-danger"><%= @suspended_forums %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-pause-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: super_admin_forums_path, method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2 align-items-center">
    <%= text_field_tag :q, params[:q], class: "form-control flex-grow-1", placeholder: "Search forums by name...", style: "min-width: 240px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ] ] + Forum.statuses.keys.map { |s| [ s.titleize, s ] }, params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", super_admin_forums_path, class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Forum</th>
          <th>URL</th>
          <th>Plan</th>
          <th>Status</th>
          <th>Chapters</th>
          <th>Collected</th>
          <th>Created</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @forums.each do |forum| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar row-avatar-<%= forum.status %>"><%= forum.name.first.upcase %></span>
                <span class="fw-semibold"><%= forum.name %></span>
              </div>
            </td>
            <td><code><%= forum_root_path(forum_slug: forum.slug) %></code></td>
            <td><% if forum.plan %>
              <span class="badge badge-plan-<%= forum.plan.key %>"><%= forum.plan.name %></span>
            <% else %>
              <span class="badge badge-plan-none">No plan</span>
            <% end %></td>
            <td><span class="badge badge-status-<%= forum.status %>"><%= forum.status.titleize %></span></td>
            <td><%= forum.chapters.count %></td>
            <td><%= number_to_currency(forum.collected_amount) %></td>
            <td><%= forum.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <%= link_to super_admin_forum_path(forum), class: "icon-btn icon-btn-view", title: "View" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <%= link_to edit_super_admin_forum_path(forum), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <% unless forum.archived? %>
                  <%= button_to super_admin_forum_path(forum), method: :delete, class: "icon-btn icon-btn-danger", title: "Archive",
                        data: { turbo_confirm: "Archive #{forum.name}? It will be hidden from active use but its data is kept." } do %>
                    <i class="bi bi-archive"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @forums.empty? %>
          <tr><td colspan="8" class="text-center text-muted py-4">No forums yet. Create the first one to get started.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @forums %>
