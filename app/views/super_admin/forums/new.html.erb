<% content_for :title, "Create Forum" %>

<div class="page-header">
  <h1 class="page-title h4">Create a New Forum</h1>
  <p class="page-subtitle mb-0">Set up the forum and its admin login in one step.</p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-9">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with url: super_admin_forums_path, method: :post, local: true, multipart: true, data: { controller: "submit-loading", action: "submit->submit-loading#start" } do |f| %>
          <h2 class="h6 text-uppercase text-muted mb-3">Forum Details</h2>
          <div class="mb-3">
            <%= label_tag "forum[name]", "Forum Name", class: "form-label" %>
            <%= text_field_tag "forum[name]", @forum&.name, class: "form-control form-control-lg", placeholder: "e.g. Krama Business Network", required: true %>
          </div>
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-8">
              <%= label_tag "forum[logo]", "Forum Logo (optional)", class: "form-label" %>
              <%= file_field_tag "forum[logo]", class: "form-control", accept: "image/*" %>
              <div class="form-text">Shown on this forum's login page and in its dashboard header. Can also be changed later from Forum Settings.</div>
            </div>
            <div class="col-12 col-sm-4">
              <%= label_tag "forum[theme_color]", "Theme Color", class: "form-label" %>
              <%= color_field_tag "forum[theme_color]", "#4f46e5", class: "form-control form-control-color w-100" %>
            </div>
          </div>

          <h2 class="h6 text-uppercase text-muted mb-3">Subscription Plan</h2>
          <div class="row g-3 mb-4">
            <% @plans.each_with_index do |plan, index| %>
              <div class="col-12 col-md-4">
                <label class="card h-100 p-3 plan-option-card">
                  <div class="form-check mb-2">
                    <%= radio_button_tag "forum[plan_id]", plan.id, index.zero?, class: "form-check-input" %>
                    <%= label_tag "forum_plan_id_#{plan.id}", "#{plan.name} (&#8377;#{number_with_delimiter(plan.price.to_i)})".html_safe, class: "form-check-label fw-semibold" %>
                  </div>
                  <ul class="list-unstyled small text-muted mb-0">
                    <% plan.features.each do |feature| %>
                      <li><i class="bi bi-check2 text-success me-1"></i><%= feature %></li>
                    <% end %>
                  </ul>
                </label>
              </div>
            <% end %>
          </div>

          <h2 class="h6 text-uppercase text-muted mb-3">Forum Admin Login</h2>
          <div class="mb-3">
            <%= label_tag "admin[email]", "Admin Email", class: "form-label" %>
            <%= email_field_tag "admin[email]", @admin&.email, class: "form-control", placeholder: "admin@example.com", required: true %>
          </div>
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6">
              <%= label_tag "admin[password]", "Password", class: "form-label" %>
              <div class="input-group" data-controller="password-toggle">
                <%= password_field_tag "admin[password]", nil, class: "form-control", required: true, minlength: 6, autocomplete: "new-password", data: { password_toggle_target: "input" } %>
                <button type="button" class="btn btn-outline-secondary" data-action="password-toggle#toggle" aria-label="Show password" tabindex="-1">
                  <i class="bi bi-eye" data-password-toggle-target="icon"></i>
                </button>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <%= label_tag "admin[password_confirmation]", "Confirm Password", class: "form-label" %>
              <div class="input-group" data-controller="password-toggle">
                <%= password_field_tag "admin[password_confirmation]", nil, class: "form-control", required: true, minlength: 6, autocomplete: "new-password", data: { password_toggle_target: "input" } %>
                <button type="button" class="btn btn-outline-secondary" data-action="password-toggle#toggle" aria-label="Show password confirmation" tabindex="-1">
                  <i class="bi bi-eye" data-password-toggle-target="icon"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary btn-lg" data-submit-loading-target="button" data-loading-text="Creating...">
              <span data-submit-loading-target="spinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
              <span data-submit-loading-target="label">Create Forum</span>
            </button>
            <%= link_to "Cancel", super_admin_forums_path, class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
