<% content_for :title, "Payments" %>

<div class="page-header">
  <h1 class="page-title h4">Payments</h1>
  <p class="page-subtitle mb-0">All recorded payments across the platform.</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Payments</div>
        <div class="mini-stat-value text-primary"><%= @total_payments %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-receipt"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Amount</div>
        <div class="mini-stat-value text-success">&#8377;<%= number_with_delimiter(@total_amount.to_i) %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-cash-coin"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">This Month</div>
        <div class="mini-stat-value text-info">&#8377;<%= number_with_delimiter(@this_month_amount.to_i) %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-graph-up"></i></div>
    </div>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Date</th>
          <th>Forum</th>
          <th>Invoice</th>
          <th>Amount</th>
          <th>Method</th>
          <th>Recorded By</th>
        </tr>
      </thead>
      <tbody>
        <% @payments.each do |payment| %>
          <tr>
            <td><%= payment.paid_on.strftime("%d %b %Y") %></td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-cash-coin"></i></span>
                <span><%= payment.invoice.forum.name %></span>
              </div>
            </td>
            <td><%= link_to payment.invoice.invoice_number, super_admin_invoice_path(payment.invoice) %></td>
            <td>&#8377;<%= number_with_delimiter(payment.amount.to_i) %></td>
            <td><%= payment.payment_method.titleize %></td>
            <td><%= payment.recorded_by.email %></td>
          </tr>
        <% end %>
        <% if @payments.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No payments recorded yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @payments %>
