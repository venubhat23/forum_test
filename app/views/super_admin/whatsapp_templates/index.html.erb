<% content_for :title, "WhatsApp Templates" %>

<div class="page-header">
  <h1 class="page-title h4">WhatsApp Templates</h1>
  <p class="page-subtitle mb-0">Platform-wide default wording for every WhatsApp message the app sends. Forums can override any of these with their own wording; anything left as Default falls back to what's set here.</p>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Message</th>
          <th>Preview</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @keys.each do |key| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-whatsapp"></i></span>
                <span class="fw-semibold"><%= WhatsappTemplate::LABELS.fetch(key) %></span>
              </div>
            </td>
            <td class="text-muted small"><%= truncate(WhatsappTemplate.resolve_body(nil, key).gsub(/\s+/, " "), length: 90) %></td>
            <td>
              <% if @customized_keys.include?(key) %>
                <span class="badge bg-success">Customized</span>
              <% else %>
                <span class="badge bg-secondary">Default</span>
              <% end %>
            </td>
            <td class="text-end">
              <%= link_to edit_super_admin_whatsapp_template_path(key), class: "icon-btn", title: "Edit" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
