<% content_for :title, "Billing Settings" %>

<div class="page-header">
  <h1 class="page-title h4">Billing Settings</h1>
  <p class="page-subtitle mb-0">Platform-wide invoicing defaults.</p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @setting, url: super_admin_billing_path, method: :patch, local: true do |f| %>
          <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
              <%= f.label :site_name, class: "form-label" %>
              <%= f.text_field :site_name, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-md-6">
              <%= f.label :support_email, class: "form-label" %>
              <%= f.email_field :support_email, class: "form-control" %>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
              <%= f.label :currency, class: "form-label" %>
              <%= f.text_field :currency, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-md-4">
              <%= f.label :invoice_prefix, class: "form-label" %>
              <%= f.text_field :invoice_prefix, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-md-4">
              <%= f.label :tax_percent, class: "form-label" %>
              <%= f.number_field :tax_percent, class: "form-control", step: "0.01", min: 0 %>
            </div>
          </div>

          <div class="mb-4">
            <%= f.label :default_plan_id, "Default plan for new forums", class: "form-label" %>
            <%= f.collection_select :default_plan_id, @plans, :id, :name, { include_blank: "None" }, class: "form-select" %>
          </div>

          <%= f.submit "Save Settings", class: "btn btn-primary btn-lg" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
