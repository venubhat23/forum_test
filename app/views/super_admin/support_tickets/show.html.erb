<% content_for :title, @ticket.subject %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @ticket.subject %></h1>
    <p class="page-subtitle mb-0"><%= @ticket.forum&.name %> &middot; raised by <%= @ticket.raised_by.email %></p>
  </div>
  <%= form_with url: change_status_super_admin_support_ticket_path(@ticket), method: :patch, local: true do %>
    <div class="d-flex gap-2">
      <%= select_tag :status, options_for_select(SupportTicket.statuses.keys.map { |s| [ s.titleize, s ] }, @ticket.status), class: "form-select" %>
      <%= submit_tag "Update Status", class: "btn btn-outline-primary" %>
    </div>
  <% end %>
</div>

<div class="card mb-4">
  <div class="card-header fw-semibold"><%= @ticket.raised_by.email %> &middot; <%= @ticket.created_at.strftime("%d %b %Y") %></div>
  <div class="card-body"><%= @ticket.body %></div>
</div>

<% @ticket.replies.order(:created_at).each do |reply| %>
  <div class="card mb-3">
    <div class="card-header fw-semibold"><%= reply.user.display_name %> &middot; <%= reply.created_at.strftime("%d %b %Y %H:%M") %></div>
    <div class="card-body"><%= reply.body %></div>
  </div>
<% end %>

<% unless @ticket.closed? %>
  <div class="card">
    <div class="card-header fw-semibold">Reply</div>
    <div class="card-body">
      <%= form_with url: reply_super_admin_support_ticket_path(@ticket), method: :post, local: true do %>
        <div class="mb-3">
          <%= text_area_tag :body, nil, class: "form-control", rows: 3, required: true %>
        </div>
        <%= submit_tag "Reply", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
<% end %>
