<div class="d-flex flex-column align-items-center justify-content-center text-center py-5 px-3" style="min-height: 60vh;">
  <i class="bi bi-hourglass-split mb-3" style="font-size: 2.5rem;"></i>
  <h2 class="mb-2">Your account isn't assigned to a forum yet</h2>
  <p class="text-muted mb-4" style="max-width: 32rem;">
    Your account (<%= current_user.email %>) hasn't been linked to a business forum. Please contact your platform administrator to complete your setup.
  </p>
  <%= link_to "Logout", destroy_user_session_path, class: "btn btn-outline-secondary", data: { turbo_method: :delete } %>
</div>
