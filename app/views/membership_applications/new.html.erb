<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <div class="auth-brand-icon">
        <i class="bi bi-person-plus"></i>
      </div>
      <h1 class="h4 fw-bold mb-1">Apply for Membership</h1>
      <p class="text-muted mb-0"><%= @forum.name %></p>
    </div>

    <% if @application.errors.any? %>
      <div class="alert alert-danger"><%= @application.errors.full_messages.to_sentence %></div>
    <% end %>

    <%= form_with model: @application, url: forum_apply_path(forum_slug: @forum.slug), local: true do |f| %>
      <div class="mb-3">
        <%= f.label :name, "Your Name", class: "form-label" %>
        <%= f.text_field :name, class: "form-control form-control-lg", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-control form-control-lg", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :phone, class: "form-label" %>
        <%= f.text_field :phone, class: "form-control form-control-lg" %>
      </div>
      <div class="mb-3">
        <%= f.label :business_name, "Business Name", class: "form-label" %>
        <%= f.text_field :business_name, class: "form-control form-control-lg" %>
      </div>
      <div class="mb-4">
        <%= f.label :nature_of_business, "Nature of Business", class: "form-label" %>
        <%= f.text_field :nature_of_business, class: "form-control form-control-lg" %>
      </div>
      <%= f.submit "Submit Application", class: "btn btn-primary btn-lg w-100" %>
    <% end %>

    <div class="text-center mt-4">
      <%= link_to "Already a member? Sign in", new_user_session_path %>
    </div>
  </div>
</div>
