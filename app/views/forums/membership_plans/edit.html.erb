<% content_for :title, "Edit #{@plan.name}" %>

<div class="page-header">
  <h1 class="page-title h4">Edit <%= @plan.name %></h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", plan: @plan, url: forum_membership_plan_path(forum_slug: @current_forum.slug, id: @plan.id), method: :patch %>
      </div>
    </div>
  </div>
</div>
