<% content_for :title, "Membership Plans" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Membership Plans</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, MembershipPlan %>
    <%= link_to new_forum_membership_plan_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> New Plan
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Cycle</th>
          <th>Price</th>
          <th>Members</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @plans.each do |plan| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-card-list"></i></span>
                <span class="fw-semibold"><%= plan.name %></span>
              </div>
            </td>
            <td><%= plan.cycle.titleize %></td>
            <td>&#8377;<%= number_with_delimiter(plan.price.to_i) %></td>
            <td><%= plan.users.count %></td>
            <td class="text-end">
              <% if can? :update, plan %>
                <div class="d-flex gap-1 justify-content-end">
                  <%= link_to edit_forum_membership_plan_path(forum_slug: @current_forum.slug, id: plan.id), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to forum_membership_plan_path(forum_slug: @current_forum.slug, id: plan.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                        data: { turbo_confirm: "Delete #{plan.name}?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @plans.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No membership plans yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
