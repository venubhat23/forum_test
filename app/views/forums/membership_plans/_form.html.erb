<%= form_with model: plan, url: url, method: method, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :cycle, class: "form-label" %>
      <%= f.select :cycle, MembershipPlan.cycles.keys.map { |k| [ k.titleize, k ] }, {}, class: "form-select" %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :price, "Price (INR)", class: "form-label" %>
      <%= f.number_field :price, class: "form-control", step: "0.01", min: 0, required: true %>
    </div>
  </div>
  <div class="mb-4">
    <%= f.label :renewal_rules, class: "form-label" %>
    <%= f.text_area :renewal_rules, class: "form-control", rows: 3 %>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", forum_membership_plans_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
