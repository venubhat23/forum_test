<% content_for :title, "Members · #{@current_forum.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Members</h1>
    <p class="page-subtitle mb-0">All members across <%= @current_forum.name %></p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Members</div>
        <div class="mini-stat-value text-primary"><%= @total_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-people"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Suspended</div>
        <div class="mini-stat-value text-danger"><%= @suspended_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-pause-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_members_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name or email...", style: "max-width: 280px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Active", "active" ], [ "Suspended", "suspended" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_members_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Chapter</th>
          <th>Business</th>
          <th>Role</th>
          <th>Status</th>
          <th>Invoice</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @members.each do |member| %>
          <% fee = @annual_fees_by_user[member.id] %>
          <% fee_paid_current = fee&.paid? && member.renews_on.present? && member.renews_on >= Date.current %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= member.full_name.first.upcase %></span>
                <span class="fw-semibold"><%= member.full_name %></span>
              </div>
            </td>
            <td><%= member.phone %></td>
            <td><%= member.chapter&.name %></td>
            <td><%= member.business_name %></td>
            <td>
              <% if member.designation.present? %>
                <span class="badge bg-primary"><%= member.designation %></span>
              <% else %>
                <span class="badge bg-secondary">Member</span>
              <% end %>
            </td>
            <td>
              <% if member.suspended_at.present? %>
                <span class="badge badge-status-suspended">Suspended</span>
              <% else %>
                <span class="badge badge-status-active">Active</span>
              <% end %>
            </td>
            <td>
              <% if fee_paid_current %>
                <span class="badge badge-status-active"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
              <% elsif fee&.partially_paid? %>
                <span class="badge badge-status-partial"><i class="bi bi-exclamation-triangle-fill me-1"></i>Partially Paid</span>
              <% else %>
                <span class="badge badge-status-trial"><i class="bi bi-exclamation-circle-fill me-1"></i>Not Paid</span>
              <% end %>
            </td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <% if fee && member.chapter_id.present? %>
                  <%= link_to print_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: member.chapter_id, id: fee.id), class: "icon-btn icon-btn-view", title: "Invoice", target: "_blank" do %>
                    <i class="bi bi-receipt"></i>
                  <% end %>
                <% end %>
                <% if member.chapter_id.present? %>
                  <%= link_to forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: member.chapter_id, id: member.id), class: "icon-btn icon-btn-view", title: "View" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @members.empty? %>
          <tr><td colspan="8" class="text-center text-muted py-4">No members yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @members %>
