<%# locals: member %>
<div class="modal fade" id="collect-fee-<%= member.id %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" data-controller="lifetime-toggle">
      <%= form_with model: FeePayment.new, url: forum_chapter_fee_payments_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), scope: :fee_payment, local: true do |f| %>
        <%= hidden_field_tag "fee_payment[user_id]", member.id %>
        <%= hidden_field_tag "fee_payment[fee_type]", "annual_membership" %>
        <div class="modal-header">
          <h5 class="modal-title mb-0"><i class="bi bi-cash-coin me-1"></i> Membership Fee &middot; <%= member.display_name %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <%= f.label :amount, "Membership Fee Amount", class: "form-label" %>
            <%= f.number_field :amount, step: "0.01", min: "0.01", class: "form-control", required: true %>
          </div>
          <div class="mb-3" data-lifetime-toggle-target="durationWrap">
            <label class="form-label">Membership Duration</label>
            <%= select_tag "fee_payment[duration_years]", options_for_select([
                  [ "1 Year", 1 ], [ "2 Years", 2 ], [ "3 Years", 3 ], [ "5 Years", 5 ], [ "10 Years", 10 ]
                ], 1), class: "form-select", data: { lifetime_toggle_target: "durationField" } %>
          </div>
          <div class="form-check mb-3">
            <%= check_box_tag "fee_payment[lifetime]", "1", false, class: "form-check-input", id: "lifetime-check-#{member.id}",
                  data: { lifetime_toggle_target: "checkbox", action: "change->lifetime-toggle#toggle" } %>
            <%= label_tag "lifetime-check-#{member.id}", "This is a one-time Lifetime Membership", class: "form-check-label" %>
          </div>
          <div class="form-check mb-2">
            <%= check_box_tag "fee_payment[mark_as_paid]", "1", true, class: "form-check-input", id: "mark-paid-#{member.id}" %>
            <%= label_tag "mark-paid-#{member.id}", "Payment received — mark as paid now", class: "form-check-label" %>
            <div class="form-text">Leave unchecked to record the fee as pending and collect payment later.</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= submit_tag "Save Membership Fee", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
