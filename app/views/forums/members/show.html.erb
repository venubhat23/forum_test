<% content_for :title, @member.display_name %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @member.display_name %></h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @member.email %></p>
  </div>
  <% if can? :update, @member %>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Edit", edit_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), class: "btn btn-outline-secondary" %>
      <%= link_to "Print ID Card", print_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), class: "btn btn-outline-secondary", target: "_blank" %>
      <% if @member.suspended? %>
        <%= button_to "Reactivate", activate_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), method: :patch, class: "btn btn-success" %>
      <% else %>
        <%= button_to "Suspend", suspend_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), method: :patch, class: "btn btn-outline-danger",
              data: { turbo_confirm: "Suspend #{@member.display_name}?" } %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-purple"><i class="bi bi-shield-check"></i></div>
      <div>
        <div class="stats-value"><span class="badge <%= @member.suspended? ? 'bg-danger' : 'bg-success' %>"><%= @member.suspended? ? "Suspended" : "Active" %></span></div>
        <div class="stats-label">Account</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-blue"><i class="bi bi-arrow-repeat"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @member.renews_on&.strftime("%d %b %Y") || "&mdash;".html_safe %></div>
        <div class="stats-label">Membership Renews</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-green"><i class="bi bi-calendar3"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @member.created_at.strftime("%d %b %Y") %></div>
        <div class="stats-label">Joined</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-indigo"><i class="bi bi-briefcase"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @member.business_name.presence || "&mdash;".html_safe %></div>
        <div class="stats-label">Business</div>
      </div>
    </div>
  </div>
</div>

<% if can?(:update, @member) && @paid_annual_fee.blank? %>
  <div class="card mb-4 border-0" style="background: linear-gradient(135deg, #eef2ff 0%, #f5f3ff 100%);">
    <div class="card-body">
      <%= render "forums/shared/conversion_progress", step: 2 %>
      <% if @pending_annual_fee %>
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <h2 class="h6 mb-1"><i class="bi bi-hourglass-split text-warning me-1"></i> Membership fee pending</h2>
            <p class="text-muted mb-0">
              <%= number_to_currency(@pending_annual_fee.balance_due) %> due for
              <%= @pending_annual_fee.lifetime? ? "a lifetime membership" : "#{@pending_annual_fee.duration_years || 1} year(s)" %> of membership.
              Once paid, <%= @member.display_name %> becomes a fully active member.
            </p>
          </div>
          <button type="button" class="btn btn-success btn-lg" data-bs-toggle="modal" data-bs-target="#record-payment-<%= @pending_annual_fee.id %>">
            <i class="bi bi-check-circle me-1"></i> Mark as Paid
          </button>
        </div>
        <%= render "forums/fee_payments/record_payment_modal", fee: @pending_annual_fee, user: @member %>
      <% else %>
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <h2 class="h6 mb-1"><i class="bi bi-cash-coin text-primary me-1"></i> Collect the membership fee</h2>
            <p class="text-muted mb-0">Set the amount and how long this membership covers — a year, several years, or a one-time lifetime fee.</p>
          </div>
          <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#collect-fee-<%= @member.id %>">
            <i class="bi bi-cash-coin me-1"></i> Collect Membership Fee
          </button>
        </div>
        <%= render "collect_fee_modal", member: @member %>
      <% end %>
    </div>
  </div>
<% elsif can?(:update, @member) && @paid_annual_fee.present? %>
  <div class="card mb-4 border-0" style="background: linear-gradient(135deg, #ecfdf5 0%, #f0fdfa 100%);">
    <div class="card-body">
      <%= render "forums/shared/conversion_progress", step: 3 %>
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
          <h2 class="h6 mb-1"><i class="bi bi-patch-check-fill text-success me-1"></i> Fully converted &middot; Membership active</h2>
          <p class="text-muted mb-0">
            <%= @member.display_name %> is now
            <%= @member.lifetime_member? ? "a lifetime member 🎉" : "a member until #{@member.renews_on&.strftime('%d %b %Y')}" %>.
          </p>
        </div>
        <% if (link = whatsapp_welcome_link(@member, @current_forum)) %>
          <%= link_to link, class: "btn btn-lg", style: "background:#25d366; color:#fff;", target: "_blank", rel: "noopener" do %>
            <i class="bi bi-whatsapp me-1"></i> Send Congratulations via WhatsApp
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if can? :update, @member %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Account Actions</div>
    <div class="card-body d-flex flex-wrap gap-2">
      <%= button_to "Reset Password", reset_password_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), method: :post, class: "btn btn-outline-warning",
            data: { turbo_confirm: "Generate a new password for #{@member.email}?" } %>
      <%= button_to "Force Logout", force_logout_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), method: :post, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Sign #{@member.email} out of all active sessions?" } %>
      <%= button_to "Renew Membership (+1 year)", renew_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @member.id), method: :patch, class: "btn btn-outline-primary" %>
    </div>
  </div>
<% end %>

<div class="card">
  <div class="card-header fw-semibold">Profile</div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Phone</dt><dd class="col-sm-9"><%= @member.phone %></dd>
      <dt class="col-sm-3">Business Category</dt><dd class="col-sm-9"><%= @member.business_category_id ? @member.business_category_ref&.name : @member.business_category %></dd>
      <dt class="col-sm-3">Speciality</dt><dd class="col-sm-9"><%= @member.speciality %></dd>
      <dt class="col-sm-3">Website</dt><dd class="col-sm-9"><%= @member.website %></dd>
      <dt class="col-sm-3">GST</dt><dd class="col-sm-9"><%= @member.gst_number %></dd>
      <dt class="col-sm-3">PAN</dt><dd class="col-sm-9"><%= @member.pan_number %></dd>
    </dl>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header fw-semibold">Fee Payments</div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Fee Type</th>
          <th>Amount</th>
          <th>Paid</th>
          <th>Due Date</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @fee_payments.each do |fee| %>
          <tr>
            <td><%= fee.fee_type.titleize %></td>
            <td>
              <%= number_to_currency(fee.amount) %>
              <% if fee.partially_paid? %>
                <div class="text-muted small">Balance <%= number_to_currency(fee.balance_due) %></div>
              <% end %>
            </td>
            <td><%= number_to_currency(fee.paid_amount) %></td>
            <td><%= fee.due_date&.strftime("%d %b %Y") || "—" %></td>
            <td>
              <span class="badge <%= fee.paid? ? 'badge-status-active' : (fee.partially_paid? ? 'badge-status-partial' : 'badge-status-trial') %>"><%= fee.status.titleize %></span>
            </td>
            <td class="text-end">
              <%= link_to print_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: fee.id), class: "icon-btn icon-btn-view", title: "Invoice", target: "_blank" do %>
                <i class="bi bi-receipt"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @fee_payments.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No fee payments recorded yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
