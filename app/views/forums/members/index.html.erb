<% content_for :title, "Members · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Members</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <% if can? :create, User %>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Export CSV", "#{forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id)}.csv", class: "btn btn-outline-primary" %>
      <%= link_to "Import Excel", import_forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-primary" %>
      <%= link_to new_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i> Add Member
      <% end %>
    </div>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Members</div>
        <div class="mini-stat-value text-primary"><%= @total_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-people"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Suspended</div>
        <div class="mini-stat-value text-danger"><%= @suspended_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-pause-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name or email...", style: "max-width: 280px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Active", "active" ], [ "Suspended", "suspended" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Business</th>
          <th>Category</th>
          <th>Speciality</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @members.each do |member| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= member.full_name.first.upcase %></span>
                <span class="fw-semibold"><%= member.full_name %></span>
              </div>
            </td>
            <td><%= member.email %></td>
            <td><%= member.phone %></td>
            <td><%= member.business_name %></td>
            <td><%= member.business_category %></td>
            <td><%= member.speciality %></td>
            <td class="text-end">
              <%= link_to forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: member.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @members.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">No members yet. Add the first one to get started.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @members %>
