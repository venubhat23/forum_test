<% content_for :title, "Members · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Members</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <% if can? :destroy, User %>
      <button type="button" class="btn btn-outline-danger" id="bulk-delete-members-btn" disabled data-bs-toggle="modal" data-bs-target="#bulk-delete-members-modal">
        <i class="bi bi-trash3-fill me-1"></i>Delete Selected
      </button>
    <% end %>
    <% if can? :create, User %>
      <%= link_to "Export CSV", "#{forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id)}.csv", class: "btn btn-outline-primary" %>
      <%= link_to "Import Excel", import_forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-primary" %>
      <%= link_to new_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i> Add Member
      <% end %>
    <% end %>
  </div>
</div>

<%= form_with url: bulk_destroy_forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :delete, local: true, id: "bulk-delete-members-form" do %><% end %>

<% if @upcoming_event && can?(:update, User) %>
  <div class="card mb-4">
    <div class="card-header fw-semibold"><i class="bi bi-calendar-event me-1"></i>Invite a Member to <%= @upcoming_event.title %></div>
    <div class="card-body">
      <%= form_with url: invite_to_event_forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :post, local: true, class: "d-flex flex-wrap gap-2" do %>
        <%= hidden_field_tag :event_id, @upcoming_event.id %>
        <%= select_tag :member_id, options_from_collection_for_select(@chapter.members.order(:full_name), :id, :full_name), prompt: "Choose a member...", class: "form-select", style: "max-width: 320px;", required: true %>
        <%= submit_tag "Invite", class: "btn btn-success" %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Members</div>
        <div class="mini-stat-value text-primary"><%= @total_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-people"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Active</div>
        <div class="mini-stat-value text-success"><%= @active_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Suspended</div>
        <div class="mini-stat-value text-danger"><%= @suspended_members %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-pause-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Renewing This Month</div>
        <div class="mini-stat-value text-warning"><%= @renewing_this_month %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-arrow-repeat"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name or email...", style: "max-width: 280px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Active", "active" ], [ "Suspended", "suspended" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th><input type="checkbox" class="form-check-input" id="select-all-members"></th>
          <th>Name</th>
          <th>Email</th>
          <th>Business</th>
          <th>Role</th>
          <th>Annual Fee</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @members.each do |member| %>
          <% fee = @annual_fees_by_user[member.id] %>
          <% fee_paid_current = fee&.paid? && member.renews_on.present? && member.renews_on >= Date.current %>
          <tr>
            <td>
              <% if can? :destroy, member %>
                <input type="checkbox" class="form-check-input member-select-checkbox" name="member_ids[]" value="<%= member.id %>"
                       form="bulk-delete-members-form" data-member-name="<%= member.full_name %>">
              <% end %>
            </td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= member.full_name.first.upcase %></span>
                <div>
                  <span class="fw-semibold d-block"><%= member.full_name %></span>
                  <span class="text-muted small"><%= member.phone %></span>
                </div>
              </div>
            </td>
            <td><%= member.email %></td>
            <td><%= member.business_name %></td>
            <td>
              <% if member.designation.present? %>
                <span class="badge bg-primary"><%= member.designation %></span>
              <% else %>
                <span class="badge bg-secondary">Member</span>
              <% end %>
              <% if can? :update, member %>
                <%= form_with url: update_role_forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: member.id), method: :patch, local: true, class: "mt-1" do %>
                  <%= select_tag :designation, options_for_select([ [ "Member (no role)", "" ] ] + User::DESIGNATIONS, member.designation), class: "form-select form-select-sm", style: "min-width: 170px;", onchange: "this.form.requestSubmit()" %>
                <% end %>
              <% end %>
            </td>
            <td>
              <% if fee_paid_current %>
                <span class="badge badge-status-active"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
              <% elsif fee&.partially_paid? %>
                <span class="badge badge-status-partial"><i class="bi bi-exclamation-triangle-fill me-1"></i>Partially Paid</span>
                <div class="text-muted small mt-1">Balance: <%= number_to_currency(fee.balance_due) %></div>
              <% else %>
                <span class="badge badge-status-trial"><i class="bi bi-exclamation-circle-fill me-1"></i>Due</span>
              <% end %>
              <div class="text-muted small mt-1">
                <%= member.renews_on ? "Renews #{member.renews_on.strftime('%d %b %Y')}" : "Renewal not set" %>
              </div>
            </td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <% if !fee_paid_current && can?(:create, FeePayment) %>
                  <% if (wa_link = whatsapp_fee_reminder_link(member, fee, @current_forum)) %>
                    <%= link_to wa_link, class: "icon-btn icon-btn-whatsapp", title: "Remind to pay via WhatsApp", target: "_blank", rel: "noopener" do %>
                      <i class="bi bi-whatsapp"></i>
                    <% end %>
                  <% end %>
                  <% if fee && !fee.paid? %>
                    <button type="button" class="icon-btn icon-btn-success" title="Record Payment (full or partial)" data-bs-toggle="modal" data-bs-target="#record-payment-<%= fee.id %>">
                      <i class="bi bi-cash-coin"></i>
                    </button>
                    <%= render "forums/fee_payments/record_payment_modal", fee: fee, user: member %>
                  <% else %>
                    <%= link_to new_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, user_id: member.id, fee_type: "annual_membership"), class: "icon-btn icon-btn-view", title: "Record Annual Fee" do %>
                      <i class="bi bi-cash-coin"></i>
                    <% end %>
                  <% end %>
                <% end %>
                <%= link_to forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: member.id), class: "icon-btn icon-btn-view", title: "View" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <% if can? :destroy, member %>
                  <%= button_to forum_chapter_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: member.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete Permanently",
                        data: { turbo_confirm: "Permanently delete #{member.full_name}? This will also permanently delete all their fee payments, attendance records, referrals, leads, event registrations, notifications, badges, support tickets, and other data. This cannot be undone." } do %>
                    <i class="bi bi-trash3-fill"></i>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @members.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">No members yet. Add the first one to get started.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @members %>

<% if can? :destroy, User %>
  <div class="modal fade" id="bulk-delete-members-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Permanently delete <span id="bulk-delete-members-count"></span> member(s)?</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>This will <strong>permanently delete</strong> the following members and <strong>all their data</strong> —
          fee payments, attendance records, referrals, leads, event registrations, notifications, badges, support
          tickets, and every other associated record. This cannot be undone.</p>
          <ul id="bulk-delete-members-list" class="mb-3"></ul>
          <p>Type <strong>DELETE</strong> to confirm:</p>
          <input type="text" class="form-control" id="bulk-delete-members-confirm-input" autocomplete="off" oninput="checkBulkDeleteMembersInput()">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger" form="bulk-delete-members-form" id="bulk-delete-members-submit-btn" disabled>Delete Forever</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function checkBulkDeleteMembersInput() {
      var input = document.getElementById('bulk-delete-members-confirm-input');
      document.getElementById('bulk-delete-members-submit-btn').disabled = (input.value !== 'DELETE');
    }

    function updateBulkDeleteMembersButton() {
      var checked = document.querySelectorAll('.member-select-checkbox:checked');
      var bulkBtn = document.getElementById('bulk-delete-members-btn');
      bulkBtn.disabled = checked.length === 0;

      var list = document.getElementById('bulk-delete-members-list');
      list.innerHTML = '';
      checked.forEach(function(cb) {
        var li = document.createElement('li');
        li.textContent = cb.dataset.memberName;
        list.appendChild(li);
      });
      document.getElementById('bulk-delete-members-count').textContent = checked.length;
    }

    document.addEventListener('turbo:load', function() {
      document.querySelectorAll('.member-select-checkbox').forEach(function(cb) {
        cb.addEventListener('change', updateBulkDeleteMembersButton);
      });

      var selectAll = document.getElementById('select-all-members');
      if (selectAll) {
        selectAll.addEventListener('change', function() {
          document.querySelectorAll('.member-select-checkbox').forEach(function(cb) { cb.checked = selectAll.checked; });
          updateBulkDeleteMembersButton();
        });
      }

      var bulkInput = document.getElementById('bulk-delete-members-confirm-input');
      if (bulkInput) bulkInput.value = '';
    });
  </script>
<% end %>
