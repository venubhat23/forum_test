<% content_for :title, "Import Members" %>

<div class="page-header">
  <h1 class="page-title h4">Import Members from Excel</h1>
  <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <p class="text-muted small">
          Upload an <code>.xlsx</code> file with columns: <code>full_name</code>, <code>email</code>, <code>phone</code>, <code>business_name</code>.
          A random password is generated for each imported member (use "Reset Password" per member afterward to hand out real credentials).
        </p>
        <%= form_with url: bulk_import_forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :post, local: true, multipart: true do %>
          <div class="mb-4">
            <%= file_field_tag :file, accept: ".xlsx,.xls,.csv", class: "form-control", required: true %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= submit_tag "Import", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_chapter_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
