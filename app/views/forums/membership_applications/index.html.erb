<% content_for :title, "Membership Applications" %>

<div class="page-header">
  <h1 class="page-title h4">Membership Applications</h1>
  <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Pending</div>
        <div class="mini-stat-value text-warning"><%= @pending_applications %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Approved</div>
        <div class="mini-stat-value text-success"><%= @approved_applications %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Rejected</div>
        <div class="mini-stat-value text-danger"><%= @rejected_applications %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-x-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_membership_applications_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ], [ "Pending", "pending" ], [ "Approved", "approved" ], [ "Rejected", "rejected" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_membership_applications_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Business</th>
          <th>Status</th>
          <th>Submitted</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @applications.each do |app| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= app.name.first.upcase %></span>
                <span class="fw-semibold"><%= app.name %></span>
              </div>
            </td>
            <td><%= app.email %></td>
            <td><%= app.business_name %></td>
            <td>
              <% case app.status
                 when "pending" %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% when "approved" %>
                <span class="badge bg-success">Approved</span>
              <% else %>
                <span class="badge bg-secondary">Rejected</span>
              <% end %>
            </td>
            <td><%= app.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to forum_membership_application_path(forum_slug: @current_forum.slug, id: app.id), class: "icon-btn icon-btn-view", title: "Review" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @applications.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No applications yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
