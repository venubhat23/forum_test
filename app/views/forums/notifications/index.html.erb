<% content_for :title, "Notifications" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Notifications</h1>
  </div>
  <% if current_user.notifications.unread.any? %>
    <%= button_to "Mark All Read", mark_all_read_forum_notifications_path(forum_slug: @current_forum.slug), method: :patch, class: "btn btn-outline-secondary" %>
  <% end %>
</div>

<div class="card">
  <div class="list-group list-group-flush">
    <% @notifications.each do |n| %>
      <div class="list-group-item d-flex justify-content-between align-items-center <%= 'bg-body-tertiary' unless n.read? %>">
        <div>
          <div><%= n.body %></div>
          <div class="text-muted small"><%= n.created_at.strftime("%d %b %Y %H:%M") %></div>
        </div>
        <% unless n.read? %>
          <%= button_to "Mark Read", mark_read_forum_notification_path(forum_slug: @current_forum.slug, id: n.id), method: :patch, class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
    <% if @notifications.empty? %>
      <div class="list-group-item text-muted text-center py-4">No notifications yet.</div>
    <% end %>
  </div>
</div>
