<% content_for :title, "#{@meeting.meeting_type.titleize} Meeting" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @meeting.meeting_type.titleize %> Meeting</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @meeting.scheduled_at.strftime("%d %b %Y %H:%M") %></p>
  </div>
  <% if can? :update, @meeting %>
    <div class="d-flex flex-wrap gap-2">
      <%= button_to "Send Reminder", remind_forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @meeting.id), method: :post, class: "btn btn-outline-primary" %>
      <%= link_to "Take Attendance", attendance_forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @meeting.id), class: "btn btn-success" %>
      <%= link_to "Edit", edit_forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @meeting.id), class: "btn btn-outline-secondary" %>
      <%= button_to "Delete", forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @meeting.id), method: :delete, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Delete this meeting?" } %>
    </div>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="stats-card">
      <div class="icon-bg gradient-blue"><i class="bi bi-geo-alt"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @meeting.venue.presence || "&mdash;".html_safe %></div>
        <div class="stats-label">Venue</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="stats-card">
      <div class="icon-bg gradient-purple"><i class="bi bi-mic"></i></div>
      <div>
        <div class="stats-value h6 mb-0"><%= @meeting.speaker.presence || "&mdash;".html_safe %></div>
        <div class="stats-label">Speaker</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="stats-card">
      <div class="icon-bg gradient-green"><i class="bi bi-graph-up"></i></div>
      <div>
        <div class="stats-value"><%= @meeting.attendance_percentage %>%</div>
        <div class="stats-label">Attendance</div>
      </div>
    </div>
  </div>
</div>

<% if @meeting.agenda.present? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Agenda</div>
    <div class="card-body"><%= simple_format(@meeting.agenda) %></div>
  </div>
<% end %>

<% if @meeting.minutes.present? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Minutes</div>
    <div class="card-body"><%= simple_format(@meeting.minutes) %></div>
  </div>
<% end %>

<% if @meeting.fee_amount.present? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Fee &amp; Payment Info</div>
    <div class="card-body">
      <p class="mb-3">Fee: <strong><%= number_to_currency(@meeting.fee_amount) %></strong></p>
      <div class="d-flex flex-wrap gap-4">
        <% if @meeting.payment_qr.attached? %>
          <div>
            <div class="text-muted small mb-1">Scan to pay</div>
            <%= image_tag @meeting.payment_qr, style: "height: 160px;" %>
          </div>
        <% end %>
        <div>
          <% if @meeting.payment_upi_id.present? %>
            <div class="mb-2"><span class="text-muted small">UPI / PhonePe:</span> <strong><%= @meeting.payment_upi_id %></strong></div>
          <% end %>
          <% if @meeting.payment_bank_details.present? %>
            <div><span class="text-muted small">Bank details:</span><br><%= simple_format(@meeting.payment_bank_details) %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if can?(:update, @meeting) && @meeting.fee_amount.present? %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-4">
      <div class="mini-stat-card">
        <div>
          <div class="mini-stat-label">Paid</div>
          <div class="mini-stat-value text-success"><%= @meeting.paid_count %></div>
        </div>
        <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
      </div>
    </div>
    <div class="col-6 col-lg-4">
      <div class="mini-stat-card">
        <div>
          <div class="mini-stat-label">Pending</div>
          <div class="mini-stat-value text-warning"><%= @meeting.pending_count %></div>
        </div>
        <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-exclamation-circle"></i></div>
      </div>
    </div>
  </div>

  <% fees_by_user = @meeting.fee_payments.order(:created_at).index_by(&:user_id) %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Member Fees</div>
    <div class="list-group list-group-flush">
      <% @chapter.members.each do |member| %>
        <% fee = fees_by_user[member.id] %>
        <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
          <span><%= member.display_name %></span>
          <div class="d-flex align-items-center gap-2">
            <% if fee&.paid? %>
              <span class="badge badge-status-active"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
            <% else %>
              <span class="badge badge-status-trial"><i class="bi bi-exclamation-circle-fill me-1"></i>Due</span>
            <% end %>
            <% if (wa_link = whatsapp_item_fee_reminder_link(member, fee, "#{@meeting.meeting_type.titleize} Meeting", @current_forum)) %>
              <%= link_to wa_link, class: "icon-btn icon-btn-whatsapp", title: "Remind to pay via WhatsApp", target: "_blank", rel: "noopener" do %>
                <i class="bi bi-whatsapp"></i>
              <% end %>
            <% end %>
            <% if fee&.pending? %>
              <%= button_to mark_paid_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: fee.id), method: :patch, class: "icon-btn icon-btn-success", title: "Mark Paid" do %>
                <i class="bi bi-check-lg"></i>
              <% end %>
            <% elsif fee.nil? %>
              <%= link_to new_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, user_id: member.id, fee_type: "meeting", meeting_id: @meeting.id), class: "icon-btn icon-btn-view", title: "Record Fee" do %>
                <i class="bi bi-cash-coin"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @chapter.members.empty? %>
        <div class="list-group-item text-muted text-center py-3">No members yet.</div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @meeting.documents.attached? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Documents</div>
    <div class="list-group list-group-flush">
      <% @meeting.documents.each do |doc| %>
        <div class="list-group-item"><%= link_to doc.filename, rails_blob_path(doc, disposition: "attachment") %></div>
      <% end %>
    </div>
  </div>
<% end %>

<% if can? :update, @meeting %>
  <div class="card">
    <div class="card-header fw-semibold">Defaulters (no attendance recorded)</div>
    <div class="list-group list-group-flush">
      <% @meeting.defaulters.each do |member| %>
        <div class="list-group-item"><%= member.display_name %> <span class="text-muted small"><%= member.email %></span></div>
      <% end %>
      <% if @meeting.defaulters.empty? %>
        <div class="list-group-item text-muted text-center py-3">Everyone attended, or no attendance recorded yet.</div>
      <% end %>
    </div>
  </div>
<% end %>
