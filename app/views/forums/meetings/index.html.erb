<% content_for :title, "Meetings · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Meetings</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <% if can? :create, Meeting %>
    <%= link_to new_forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Schedule Meeting
    <% end %>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Meetings</div>
        <div class="mini-stat-value text-primary"><%= @total_meetings %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-calendar3"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Avg Attendance</div>
        <div class="mini-stat-value text-success"><%= @avg_attendance %>%</div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-graph-up"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_chapter_meetings_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by venue or speaker...", style: "max-width: 260px;" %>
    <%= select_tag :meeting_type, options_for_select([ [ "All types", "" ] ] + Meeting.meeting_types.keys.map { |t| [ t.titleize, t ] }, params[:meeting_type]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_meetings_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Type</th>
          <th>Date</th>
          <th>Venue</th>
          <th>Speaker</th>
          <th>Attendance</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @meetings.each do |meeting| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-calendar3"></i></span>
                <span class="badge bg-secondary"><%= meeting.meeting_type.titleize %></span>
              </div>
            </td>
            <td><%= meeting.scheduled_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= meeting.venue %></td>
            <td><%= meeting.speaker %></td>
            <td><%= meeting.attendance_percentage %>%</td>
            <td class="text-end">
              <%= link_to forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: meeting.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @meetings.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No meetings scheduled yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @meetings %>
