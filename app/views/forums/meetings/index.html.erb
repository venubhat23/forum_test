<% content_for :title, "Meetings · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Meetings</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <% if can? :create, Meeting %>
    <%= link_to new_forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Schedule Meeting
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Type</th>
          <th>Date</th>
          <th>Venue</th>
          <th>Speaker</th>
          <th>Attendance</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @meetings.each do |meeting| %>
          <tr>
            <td><span class="badge bg-secondary"><%= meeting.meeting_type.titleize %></span></td>
            <td><%= meeting.scheduled_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= meeting.venue %></td>
            <td><%= meeting.speaker %></td>
            <td><%= meeting.attendance_percentage %>%</td>
            <td class="text-end">
              <%= link_to "View", forum_chapter_meeting_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: meeting.id), class: "btn btn-sm btn-outline-secondary" %>
            </td>
          </tr>
        <% end %>
        <% if @meetings.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No meetings scheduled yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @meetings %>
