<% content_for :title, "Committee · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Committee Members</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_chapter_committee_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Add Committee Member
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Designation</th>
          <th>Email</th>
          <th>Phone</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @committee_members.each do |cm| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= cm.full_name.first.upcase %></span>
                <span class="fw-semibold"><%= cm.full_name %></span>
              </div>
            </td>
            <td><span class="badge bg-primary"><%= cm.designation %></span></td>
            <td><%= cm.email %></td>
            <td><%= cm.phone %></td>
            <td class="text-end">
              <%= link_to forum_chapter_committee_member_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: cm.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @committee_members.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No committee members yet. Add the first one to get started.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @committee_members %>
