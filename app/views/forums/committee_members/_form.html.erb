<%= form_with model: committee_member, url: url, method: method, local: true, scope: :committee_member do |f| %>
  <h2 class="h6 text-uppercase text-muted mb-3">Profile</h2>
  <div class="mb-3">
    <%= f.label :full_name, "Full Name", class: "form-label" %>
    <%= f.text_field :full_name, class: "form-control", required: true %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :phone, "Phone Number", class: "form-label" %>
      <%= f.telephone_field :phone, class: "form-control", required: true %>
    </div>
  </div>
  <div class="mb-3">
    <%= f.label :designation, class: "form-label" %>
    <%= f.text_field :designation, class: "form-control", required: true, list: "designation-suggestions", placeholder: "e.g. President" %>
    <datalist id="designation-suggestions">
      <% User::DESIGNATIONS.each do |designation| %>
        <option value="<%= designation %>">
      <% end %>
    </datalist>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :term_starts_on, "Term Starts", class: "form-label" %>
      <%= f.date_field :term_starts_on, class: "form-control" %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :term_ends_on, "Term Ends", class: "form-label" %>
      <%= f.date_field :term_ends_on, class: "form-control" %>
    </div>
  </div>
  <div class="mb-4">
    <%= f.label :responsibilities, class: "form-label" %>
    <%= f.text_area :responsibilities, class: "form-control", rows: 3 %>
  </div>

  <% if committee_member.new_record? %>
    <h2 class="h6 text-uppercase text-muted mb-3">Login</h2>
    <div class="row g-3 mb-4">
      <div class="col-12 col-sm-6">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true, minlength: 6, autocomplete: "new-password" %>
      </div>
      <div class="col-12 col-sm-6">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control", required: true, minlength: 6, autocomplete: "new-password" %>
      </div>
    </div>
  <% end %>

  <div class="d-flex flex-wrap gap-2">
    <%= f.submit committee_member.new_record? ? "Add Committee Member" : "Save Changes", class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", forum_chapter_committee_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
