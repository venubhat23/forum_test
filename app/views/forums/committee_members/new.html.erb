<% content_for :title, "New Committee Member" %>

<div class="page-header">
  <h1 class="page-title h4">Add Committee Member</h1>
  <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", committee_member: @committee_member, url: forum_chapter_committee_members_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :post %>
      </div>
    </div>
  </div>
</div>
