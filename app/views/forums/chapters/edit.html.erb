<% content_for :title, "Edit #{@chapter.name}" %>

<div class="page-header">
  <h1 class="page-title h4">Edit <%= @chapter.name %></h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @chapter, url: forum_chapter_path(forum_slug: @current_forum.slug, id: @chapter.id), method: :patch, local: true do |f| %>
          <div class="mb-4">
            <%= f.label :name, "Chapter Name", class: "form-label" %>
            <%= f.text_field :name, class: "form-control form-control-lg", required: true %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Save Changes", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_chapter_path(forum_slug: @current_forum.slug, id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
