<% content_for :title, "Analytics" %>

<div class="page-header">
  <h1 class="page-title h4">Analytics</h1>
  <p class="page-subtitle mb-0"><%= @current_forum.name %> &middot; last 6 months</p>
</div>

<div class="row g-3">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Membership Growth</div>
      <div class="card-body"><%= line_chart @membership_growth %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Revenue Trend</div>
      <div class="card-body"><%= column_chart @revenue_trend %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Attendance Trend</div>
      <div class="card-body"><%= line_chart @attendance_trend %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Referral Trend</div>
      <div class="card-body"><%= line_chart @referral_trend %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Business Generated</div>
      <div class="card-body"><%= column_chart @business_generated_trend %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Chapter Performance (people)</div>
      <div class="card-body"><%= pie_chart @chapter_performance %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Event Participation</div>
      <div class="card-body"><%= column_chart @event_participation %></div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-header fw-semibold">Guest Conversion</div>
      <div class="card-body"><%= pie_chart @guest_conversion %></div>
    </div>
  </div>
</div>
