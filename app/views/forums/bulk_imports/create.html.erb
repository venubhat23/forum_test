<% content_for :title, "Bulk Import Results" %>

<div class="page-header">
  <h1 class="page-title h4">Bulk Import Results</h1>
  <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
</div>

<% failed_count = @results.count { |r| r[:errors].any? } %>

<% if @imported %>
  <div class="alert alert-success">
    All <%= @results.size %> row(s) imported successfully.
  </div>
<% else %>
  <div class="alert alert-danger">
    Import failed — <%= failed_count %> of <%= @results.size %> row(s) had errors. Nothing was saved; fix the reported rows and re-upload.
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Row</th>
          <th>Chapter</th>
          <th>Full Name</th>
          <th>Email</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @results.each do |r| %>
          <tr>
            <td><%= r[:row] %></td>
            <td><%= r[:chapter_name] %></td>
            <td><%= r[:full_name] %></td>
            <td><%= r[:email] %></td>
            <td>
              <% if r[:errors].any? %>
                <span class="badge bg-danger">Failed: <%= r[:errors].join("; ") %></span>
              <% elsif @imported %>
                <span class="badge bg-success">Imported</span>
              <% else %>
                <span class="badge bg-secondary">Would import</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="d-flex flex-wrap gap-2 mt-4">
  <%= link_to "Upload another file", new_forum_bulk_import_path(forum_slug: @current_forum.slug), class: "btn btn-primary" %>
  <%= link_to "View Chapters", forum_chapters_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary" %>
</div>
