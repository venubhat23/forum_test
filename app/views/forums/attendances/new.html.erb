<% content_for :title, "Record Attendance" %>

<div class="page-header">
  <h1 class="page-title h4">Record Attendance</h1>
  <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @attendance, url: forum_chapter_attendances_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), local: true, scope: :attendance do |f| %>
          <div class="mb-3">
            <%= f.label :user_id, "Member / Guest", class: "form-label" %>
            <%= f.collection_select :user_id, @people, :id, ->(person) { "#{person.display_name} (#{person.role.titleize})" }, { include_blank: "Select a person" }, class: "form-select", required: true %>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :event_type, "Event", class: "form-label" %>
              <%= f.select :event_type, Attendance.event_types.keys.map { |k| [k.titleize, k] }, { include_blank: "Select an event type" }, class: "form-select", required: true %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :occurred_on, "Date", class: "form-label" %>
              <%= f.date_field :occurred_on, class: "form-control", required: true %>
            </div>
          </div>
          <div class="form-check mb-4">
            <%= f.check_box :present, class: "form-check-input" %>
            <%= f.label :present, class: "form-check-label" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Record Attendance", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_chapter_attendances_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
