<% content_for :title, "Attendance · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Attendance</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_chapter_attendance_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Record Attendance
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total</div>
        <div class="mini-stat-value text-primary"><%= @total_attendance %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-calendar-check"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Present</div>
        <div class="mini-stat-value text-success"><%= @present_count %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Absent</div>
        <div class="mini-stat-value text-danger"><%= @absent_count %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-x-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_chapter_attendances_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by person...", style: "max-width: 260px;" %>
    <%= select_tag :status, options_for_select([ [ "All", "" ], [ "Present", "present" ], [ "Absent", "absent" ] ], params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_attendances_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Person</th>
          <th>Event</th>
          <th>Date</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= attendance.user.display_name.first.upcase %></span>
                <div>
                  <span class="fw-semibold"><%= attendance.user.display_name %></span>
                  <span class="text-muted small d-block">(<%= attendance.user.role.titleize %>)</span>
                </div>
              </div>
            </td>
            <td><%= attendance.event_type.titleize %></td>
            <td><%= attendance.occurred_on.strftime("%d %b %Y") %></td>
            <td><span class="badge <%= attendance.present? ? 'badge-status-active' : 'badge-status-suspended' %>"><%= attendance.present? ? "Present" : "Absent" %></span></td>
          </tr>
        <% end %>
        <% if @attendances.empty? %>
          <tr><td colspan="4" class="text-center text-muted py-4">No attendance recorded yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @attendances %>
