<% content_for :title, "New Guest" %>

<div class="page-header">
  <h1 class="page-title h4">Add Guest</h1>
  <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @guest, url: forum_chapter_guests_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), local: true, scope: :guest do |f| %>
          <h2 class="h6 text-uppercase text-muted mb-3">Basic Profile</h2>
          <div class="mb-3">
            <%= f.label :full_name, "Full Name", class: "form-label" %>
            <%= f.text_field :full_name, class: "form-control", required: true %>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :phone, "Phone Number", class: "form-label" %>
              <%= f.telephone_field :phone, class: "form-control", required: true %>
            </div>
          </div>
          <div class="mb-3">
            <%= f.label :nature_of_business, "Nature of Business", class: "form-label" %>
            <%= f.text_field :nature_of_business, class: "form-control", required: true %>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :business_category, "Business Category", class: "form-label" %>
              <%= f.text_field :business_category, class: "form-control" %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :speciality, class: "form-label" %>
              <%= f.text_field :speciality, class: "form-control" %>
            </div>
          </div>
          <div class="mb-4">
            <%= f.label :invited_by_id, "Invited By", class: "form-label" %>
            <%= f.collection_select :invited_by_id, @chapter.members.order(:full_name), :id, :display_name, { include_blank: "Select a member" }, class: "form-select" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Add Guest", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_chapter_guests_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
