<%= form_with model: guest, url: url, method: method, local: true, scope: :guest, data: { controller: "submit-loading", action: "submit->submit-loading#start" } do |f| %>
  <h2 class="h6 text-uppercase text-muted mb-3">Basic Profile</h2>
  <div class="mb-3">
    <%= f.label :full_name, "Full Name", class: "form-label" %>
    <%= f.text_field :full_name, class: "form-control", required: true %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :phone, "Phone Number", class: "form-label" %>
      <%= f.telephone_field :phone, class: "form-control", required: true %>
    </div>
  </div>
  <div class="mb-3">
    <%= f.label :nature_of_business, "Nature of Business", class: "form-label" %>
    <%= f.text_field :nature_of_business, class: "form-control", required: true %>
  </div>
  <% categories_map = business_categories_map(@current_forum) %>
  <div class="row g-3 mb-3" data-controller="business-category"
       data-business-category-categories-value="<%= categories_map.to_json %>"
       data-business-category-selected-value="<%= guest.speciality %>">
    <div class="col-12 col-sm-6">
      <%= f.label :business_category, "Business Category", class: "form-label" %>
      <%= f.select :business_category, categories_map.keys, {}, class: "form-select",
            data: { business_category_target: "category", action: "change->business-category#categoryChanged" } %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :speciality, class: "form-label" %>
      <%= f.select :speciality, [], {}, class: "form-select", data: { business_category_target: "speciality" } %>
    </div>
  </div>
  <div class="mb-4">
    <%= f.label :invited_by_id, "Invited By", class: "form-label" %>
    <%= f.collection_select :invited_by_id, @chapter.members.order(:full_name), :id, :display_name, { include_blank: "Select a member" }, class: "form-select" %>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <button type="submit" class="btn btn-primary btn-lg" data-submit-loading-target="button" data-loading-text="<%= guest.new_record? ? "Adding..." : "Saving..." %>">
      <span data-submit-loading-target="spinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
      <span data-submit-loading-target="label"><%= guest.new_record? ? "Add Guest" : "Save Changes" %></span>
    </button>
    <%= link_to "Cancel", forum_chapter_guests_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
