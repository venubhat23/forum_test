<% content_for :title, "Convert #{@guest.display_name} to Member" %>

<div class="page-header">
  <h1 class="page-title h4">Convert <%= @guest.display_name %> to Member</h1>
  <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <%= render "forums/shared/conversion_progress", step: 1 %>

    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @guest, url: convert_to_member_forum_chapter_guest_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @guest.id),
              method: :patch, scope: :guest, local: true, html: { multipart: true },
              data: { controller: "submit-loading", action: "submit->submit-loading#start" } do |f| %>
          <h2 class="h6 text-uppercase text-muted mb-3">Basic Profile</h2>
          <div class="mb-3">
            <%= f.label :full_name, "Owner Name", class: "form-label" %>
            <%= f.text_field :full_name, class: "form-control", required: true %>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, class: "form-control", required: true %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :phone, "Phone Number", class: "form-label" %>
              <%= f.telephone_field :phone, class: "form-control", required: true %>
            </div>
          </div>
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6">
              <%= f.label :date_of_birth, class: "form-label" %>
              <%= f.date_field :date_of_birth, class: "form-control" %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :photo, "Photo", class: "form-label" %>
              <%= f.file_field :photo, class: "form-control", accept: "image/*" %>
            </div>
          </div>

          <h2 class="h6 text-uppercase text-muted mb-3">Business Details</h2>
          <div class="mb-3">
            <%= f.label :business_name, "Business Name", class: "form-label" %>
            <%= f.text_field :business_name, class: "form-control", required: true %>
          </div>
          <div class="row g-3 mb-3" data-controller="business-category"
               data-business-category-categories-value="<%= User::BUSINESS_CATEGORIES.to_json %>"
               data-business-category-selected-value="<%= @guest.speciality %>">
            <div class="col-12 col-sm-6">
              <%= f.label :business_category, "Business Category", class: "form-label" %>
              <%= f.select :business_category, User::BUSINESS_CATEGORIES.keys, {}, class: "form-select",
                    data: { business_category_target: "category", action: "change->business-category#categoryChanged" } %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :speciality, class: "form-label" %>
              <%= f.select :speciality, [], {}, class: "form-select", data: { business_category_target: "speciality" } %>
            </div>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :business_category_id, "Category (from list)", class: "form-label" %>
              <%= f.collection_select :business_category_id, @current_forum.business_categories.order(:name), :id, :name, { include_blank: true }, class: "form-select" %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :website, class: "form-label" %>
              <%= f.text_field :website, class: "form-control", placeholder: "https://..." %>
            </div>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6">
              <%= f.label :capacity, "Business Capacity", class: "form-label" %>
              <%= f.text_field :capacity, class: "form-control", placeholder: "e.g. 500 units/month, team of 12" %>
            </div>
            <div class="col-12 col-sm-6">
              <%= f.label :service_area, "Service Coverage Area", class: "form-label" %>
              <%= f.text_field :service_area, class: "form-control", list: "service-area-suggestions", placeholder: "e.g. Only Bengaluru" %>
              <datalist id="service-area-suggestions">
                <option value="Only within the city">
                <option value="All over the district">
                <option value="All over Karnataka">
                <option value="All over India">
                <option value="Pan-India + International">
              </datalist>
            </div>
          </div>
          <div class="mb-3">
            <%= f.label :designation, "Committee Role", class: "form-label" %>
            <%= f.select :designation, User::DESIGNATIONS, { include_blank: "Member (no special role)" }, class: "form-select" %>
          </div>
          <div class="mb-4">
            <%= f.label :address, class: "form-label" %>
            <%= f.text_area :address, class: "form-control", rows: 2 %>
          </div>
          <div class="mb-4">
            <%= f.label :city, "Location (City)", class: "form-label" %>
            <%= f.text_field :city, class: "form-control" %>
          </div>

          <h2 class="h6 text-uppercase text-muted mb-3">Statutory Details</h2>
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-4">
              <%= f.label :gst_number, "GST Number", class: "form-label" %>
              <%= f.text_field :gst_number, class: "form-control" %>
            </div>
            <div class="col-12 col-sm-4">
              <%= f.label :pan_number, "PAN Number", class: "form-label" %>
              <%= f.text_field :pan_number, class: "form-control" %>
            </div>
            <div class="col-12 col-sm-4">
              <%= f.label :aadhaar_number, "Aadhaar Number", class: "form-label" %>
              <%= f.text_field :aadhaar_number, class: "form-control" %>
            </div>
          </div>

          <h2 class="h6 text-uppercase text-muted mb-3">KYC Documents</h2>
          <div class="mb-4">
            <%= f.label :kyc_documents, "Upload documents (multiple allowed)", class: "form-label" %>
            <%= f.file_field :kyc_documents, multiple: true, class: "form-control" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success btn-lg" data-submit-loading-target="button" data-loading-text="Converting...">
              <span data-submit-loading-target="spinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
              <span data-submit-loading-target="label"><i class="bi bi-arrow-right-circle me-1"></i> Convert to Member</span>
            </button>
            <%= link_to "Cancel", forum_chapter_guest_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: @guest.id), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
