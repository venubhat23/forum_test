<% content_for :title, "Guests · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Guests</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_chapter_guest_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Add Guest
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Guests</div>
        <div class="mini-stat-value text-primary"><%= @total_guests %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-person-badge"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Invited This Month</div>
        <div class="mini-stat-value text-info"><%= @guests_this_month %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-calendar-plus"></i></div>
    </div>
  </div>
</div>

<% if @upcoming_event %>
  <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
    <i class="bi bi-whatsapp fs-5"></i>
    <div>Inviting guests to <strong><%= @upcoming_event.title %></strong> (<%= @upcoming_event.starts_at.strftime("%d %b %Y") %>) — use the WhatsApp button on any guest with a phone number to send them an invite.</div>
  </div>
<% end %>

<%= form_with url: forum_chapter_guests_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name or email...", style: "max-width: 280px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_guests_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Nature of Business</th>
          <th>Invited By</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @guests.each do |guest| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= guest.full_name.first.upcase %></span>
                <span class="fw-semibold"><%= guest.full_name %></span>
              </div>
            </td>
            <td><%= guest.email %></td>
            <td><%= guest.phone %></td>
            <td><%= guest.nature_of_business %></td>
            <td><%= guest.invited_by&.display_name || "—" %></td>
            <td class="text-end">
              <% if @upcoming_event && (invite_link = whatsapp_invite_link(guest, @upcoming_event, @current_forum)) %>
                <%= link_to invite_link, class: "icon-btn icon-btn-whatsapp", title: "Invite to #{@upcoming_event.title} via WhatsApp", target: "_blank", rel: "noopener" do %>
                  <i class="bi bi-whatsapp"></i>
                <% end %>
              <% end %>
              <%= link_to forum_chapter_guest_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: guest.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @guests.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No guests yet. Add the first one to get started.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @guests %>
