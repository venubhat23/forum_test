<% content_for :title, "Events" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Events</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, Event %>
    <%= link_to new_forum_event_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Create Event
    <% end %>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Events</div>
        <div class="mini-stat-value text-primary"><%= @total_events %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-calendar-event"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Upcoming</div>
        <div class="mini-stat-value text-success"><%= @upcoming_events %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-calendar-plus"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Past</div>
        <div class="mini-stat-value text-info"><%= @past_events %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-calendar-check"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_events_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by title...", style: "max-width: 260px;" %>
    <%= select_tag :event_type, options_for_select([ [ "All types", "" ] ] + Event.event_types.keys.map { |t| [ t.titleize, t ] }, params[:event_type]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_events_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Type</th>
          <th>Date</th>
          <th>Venue</th>
          <th>Registrants</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-calendar-event"></i></span>
                <span class="fw-semibold"><%= event.title %></span>
              </div>
            </td>
            <td><span class="badge bg-secondary"><%= event.event_type.titleize %></span></td>
            <td><%= event.starts_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= event.venue %></td>
            <td><%= event.event_registrations.count %></td>
            <td class="text-end">
              <%= link_to forum_event_path(forum_slug: @current_forum.slug, id: event.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @events.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No events yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @events %>
