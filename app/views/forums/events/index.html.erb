<% content_for :title, "Events" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Events</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, Event %>
    <%= link_to new_forum_event_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Create Event
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Type</th>
          <th>Date</th>
          <th>Venue</th>
          <th>Registrants</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td class="fw-semibold"><%= event.title %></td>
            <td><span class="badge bg-secondary"><%= event.event_type.titleize %></span></td>
            <td><%= event.starts_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= event.venue %></td>
            <td><%= event.event_registrations.count %></td>
            <td class="text-end">
              <%= link_to "View", forum_event_path(forum_slug: @current_forum.slug, id: event.id), class: "btn btn-sm btn-outline-secondary" %>
            </td>
          </tr>
        <% end %>
        <% if @events.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No events yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @events %>
