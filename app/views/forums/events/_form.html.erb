<%= form_with model: event, url: url, method: method, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :event_type, class: "form-label" %>
      <%= f.select :event_type, Event.event_types.keys.map { |k| [ k.titleize, k ] }, {}, class: "form-select" %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :starts_at, "Date & Time", class: "form-label" %>
      <%= f.datetime_field :starts_at, class: "form-control", required: true %>
    </div>
  </div>
  <div class="mb-3">
    <%= f.label :venue, class: "form-label" %>
    <%= f.text_field :venue, class: "form-control" %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :registration_opens_at, "Registration Opens", class: "form-label" %>
      <%= f.datetime_field :registration_opens_at, class: "form-control" %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :registration_closes_at, "Registration Closes", class: "form-label" %>
      <%= f.datetime_field :registration_closes_at, class: "form-control" %>
    </div>
  </div>
  <div class="mb-4">
    <%= f.label :gallery, "Photo Gallery", class: "form-label" %>
    <%= f.file_field :gallery, multiple: true, class: "form-control", accept: "image/*" %>
  </div>

  <% if event.new_record? %>
    <div class="mb-4">
      <%= label_tag :member_ids, "Add Members", class: "form-label" %>
      <%= render "member_picker", members: @current_forum.users, field_name: "member_ids[]" %>
    </div>
  <% end %>

  <h2 class="h6 text-uppercase text-muted mb-3">Fee &amp; Payment Info (optional)</h2>
  <div class="mb-3">
    <%= f.label :fee_amount, "Fee Amount", class: "form-label" %>
    <%= f.number_field :fee_amount, step: 0.01, min: 0, class: "form-control", placeholder: "Leave blank if free" %>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :payment_upi_id, "UPI / PhonePe ID", class: "form-label" %>
      <%= f.text_field :payment_upi_id, class: "form-control", placeholder: "e.g. name@upi" %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :payment_qr, "Payment QR Code", class: "form-label" %>
      <%= f.file_field :payment_qr, class: "form-control", accept: "image/*" %>
      <% if event.payment_qr.attached? %>
        <div class="form-text">Current QR code: <%= image_tag event.payment_qr, style: "height: 60px; margin-top: 4px;" %></div>
      <% end %>
    </div>
  </div>
  <div class="mb-4">
    <%= f.label :payment_bank_details, "Bank Account Details", class: "form-label" %>
    <%= f.text_area :payment_bank_details, class: "form-control", rows: 2, placeholder: "Account name, number, IFSC, bank..." %>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", forum_events_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
