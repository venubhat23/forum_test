<% content_for :title, @event.title %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @event.title %></h1>
    <p class="page-subtitle mb-0"><%= @event.starts_at.strftime("%d %b %Y %H:%M") %> &middot; <%= @event.venue %></p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <% if can? :update, @event %>
      <%= button_to "Send Reminder", remind_forum_event_path(forum_slug: @current_forum.slug, id: @event.id), method: :post, class: "btn btn-outline-primary" %>
      <%= link_to "Take Attendance", attendance_forum_event_path(forum_slug: @current_forum.slug, id: @event.id), class: "btn btn-success" %>
      <%= link_to "Edit", edit_forum_event_path(forum_slug: @current_forum.slug, id: @event.id), class: "btn btn-outline-secondary" %>
      <%= button_to "Delete", forum_event_path(forum_slug: @current_forum.slug, id: @event.id), method: :delete, class: "btn btn-outline-danger",
            data: { turbo_confirm: "Delete this event?" } %>
    <% end %>
    <% if can?(:create, EventRegistration) %>
      <% if @registered %>
        <%= button_to "Cancel My Registration", forum_event_registration_path(forum_slug: @current_forum.slug, event_id: @event.id, id: @event.event_registrations.find_by(user: current_user).id), method: :delete, class: "btn btn-outline-danger" %>
      <% elsif @event.registration_open? %>
        <%= button_to "Register", forum_event_registrations_path(forum_slug: @current_forum.slug, event_id: @event.id), method: :post, class: "btn btn-success" %>
      <% else %>
        <span class="badge bg-secondary align-self-center">Registration Closed</span>
      <% end %>
    <% end %>
  </div>
</div>

<% if @event.fee_amount.present? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Fee &amp; Payment Info</div>
    <div class="card-body">
      <p class="mb-3">Fee: <strong><%= number_to_currency(@event.fee_amount) %></strong></p>
      <div class="d-flex flex-wrap gap-4">
        <% if @event.payment_qr.attached? %>
          <div>
            <div class="text-muted small mb-1">Scan to pay</div>
            <%= image_tag @event.payment_qr, style: "height: 160px;" %>
          </div>
        <% end %>
        <div>
          <% if @event.payment_upi_id.present? %>
            <div class="mb-2"><span class="text-muted small">UPI / PhonePe:</span> <strong><%= @event.payment_upi_id %></strong></div>
          <% end %>
          <% if @event.payment_bank_details.present? %>
            <div><span class="text-muted small">Bank details:</span><br><%= simple_format(@event.payment_bank_details) %></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if can?(:update, @event) && @event.fee_amount.present? %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-4">
      <div class="mini-stat-card">
        <div>
          <div class="mini-stat-label">Paid</div>
          <div class="mini-stat-value text-success"><%= @event.paid_count %></div>
        </div>
        <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
      </div>
    </div>
    <div class="col-6 col-lg-4">
      <div class="mini-stat-card">
        <div>
          <div class="mini-stat-label">Pending</div>
          <div class="mini-stat-value text-warning"><%= @event.pending_count %></div>
        </div>
        <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-exclamation-circle"></i></div>
      </div>
    </div>
    <div class="col-6 col-lg-4">
      <div class="mini-stat-card">
        <div>
          <div class="mini-stat-label">Collected</div>
          <div class="mini-stat-value text-primary"><%= number_to_currency(@event.collected_amount) %></div>
        </div>
        <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-cash-stack"></i></div>
      </div>
    </div>
  </div>

  <% fees_by_user = @event.fee_payments.order(:created_at).index_by(&:user_id) %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Registrant Fees</div>
    <div class="list-group list-group-flush">
      <% @event.registrants.each do |registrant| %>
        <% fee = fees_by_user[registrant.id] %>
        <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
          <span><%= registrant.display_name %></span>
          <div class="d-flex align-items-center gap-2">
            <% if fee&.paid? %>
              <span class="badge badge-status-active"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
            <% else %>
              <span class="badge badge-status-trial"><i class="bi bi-exclamation-circle-fill me-1"></i>Due</span>
            <% end %>
            <% if (wa_link = whatsapp_item_fee_reminder_link(registrant, fee, @event.title, @current_forum)) %>
              <%= link_to wa_link, class: "icon-btn icon-btn-whatsapp", title: "Remind to pay via WhatsApp", target: "_blank", rel: "noopener" do %>
                <i class="bi bi-whatsapp"></i>
              <% end %>
            <% end %>
            <% if fee&.pending? %>
              <%= button_to mark_paid_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: registrant.chapter_id, id: fee.id), method: :patch, class: "icon-btn icon-btn-success", title: "Mark Paid" do %>
                <i class="bi bi-check-lg"></i>
              <% end %>
            <% elsif fee.nil? %>
              <%= link_to new_forum_chapter_fee_payment_path(forum_slug: @current_forum.slug, chapter_id: registrant.chapter_id, user_id: registrant.id, fee_type: "event", event_id: @event.id), class: "icon-btn icon-btn-view", title: "Record Fee" do %>
                <i class="bi bi-cash-coin"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @event.registrants.empty? %>
        <div class="list-group-item text-muted text-center py-3">No registrants yet.</div>
      <% end %>
    </div>
  </div>
<% end %>


<% if can? :update, @event %>
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="fw-semibold">Ledger</span>
      <%= link_to new_forum_expense_path(forum_slug: @current_forum.slug, event_id: @event.id), class: "btn btn-sm btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i> Add Expense
      <% end %>
    </div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        <div class="col-6 col-lg-4">
          <div class="mini-stat-card">
            <div>
              <div class="mini-stat-label">Entry Fees Collected</div>
              <div class="mini-stat-value text-success"><%= number_to_currency(@event.collected_amount) %></div>
            </div>
            <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-cash-stack"></i></div>
          </div>
        </div>
        <div class="col-6 col-lg-4">
          <div class="mini-stat-card">
            <div>
              <div class="mini-stat-label">Total Expenses</div>
              <div class="mini-stat-value text-danger"><%= number_to_currency(@event.total_expenses) %></div>
            </div>
            <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-receipt"></i></div>
          </div>
        </div>
        <div class="col-6 col-lg-4">
          <div class="mini-stat-card">
            <div>
              <div class="mini-stat-label"><%= @event.net_amount.negative? ? "Net Loss" : "Net Saved" %></div>
              <div class="mini-stat-value <%= @event.net_amount.negative? ? "text-danger" : "text-primary" %>"><%= number_to_currency(@event.net_amount) %></div>
            </div>
            <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-piggy-bank"></i></div>
          </div>
        </div>
      </div>

      <div class="list-group list-group-flush">
        <% @event.expenses.order(incurred_on: :desc).each do |expense| %>
          <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
              <span class="fw-semibold"><%= expense.category %></span>
              <span class="text-muted small d-block"><%= expense.incurred_on.strftime("%d %b %Y") %><%= " · #{expense.notes}" if expense.notes.present? %></span>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="fw-semibold text-danger"><%= number_to_currency(expense.amount) %></span>
              <%= link_to edit_forum_expense_path(forum_slug: @current_forum.slug, id: expense.id), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to forum_expense_path(forum_slug: @current_forum.slug, id: expense.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                    data: { turbo_confirm: "Delete this expense?" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          </div>
        <% end %>
        <% if @event.expenses.empty? %>
          <div class="list-group-item text-muted text-center py-3">No expenses recorded yet.</div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @event.gallery.attached? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Gallery</div>
    <div class="card-body d-flex flex-wrap gap-2">
      <% @event.gallery.each do |photo| %>
        <%= link_to photo.filename, rails_blob_path(photo, disposition: "attachment") %>
      <% end %>
    </div>
  </div>
<% end %>


<% if can?(:update, @event) && @event.event_registrations.any? %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-4">
      <div class="stats-card">
        <div class="icon-bg gradient-green"><i class="bi bi-graph-up"></i></div>
        <div>
          <div class="stats-value"><%= @event.attendance_percentage %>%</div>
          <div class="stats-label">Attendance</div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% if can? :read, EventRegistration %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Registrants (<%= @event.event_registrations.count %>)</div>
    <% if @addable_members.present? %>
      <div class="card-body border-bottom">
        <%= form_with url: forum_event_registrations_path(forum_slug: @current_forum.slug, event_id: @event.id), method: :post, local: true, class: "d-flex flex-wrap gap-2" do %>
          <%= select_tag :user_id, options_from_collection_for_select(@addable_members, :id, :display_name), prompt: "Add a member...", class: "form-select", style: "max-width: 280px;" %>
          <%= submit_tag "Add", class: "btn btn-outline-primary" %>
        <% end %>
      </div>
    <% end %>
    <div class="list-group list-group-flush">
      <% @event.event_registrations.includes(:user).each do |reg| %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <span><%= reg.user.display_name %></span>
          <span class="badge <%= reg.attended? ? 'bg-success' : 'bg-secondary' %>"><%= reg.attended? ? "Attended" : "Registered" %></span>
        </div>
      <% end %>
      <% if @event.event_registrations.empty? %>
        <div class="list-group-item text-muted text-center py-3">No registrations yet.</div>
      <% end %>
    </div>
  </div>
<% end %>

<% if can? :update, @event %>
  <div class="card">
    <div class="card-header fw-semibold">Defaulters (registered but not marked present)</div>
    <div class="list-group list-group-flush">
      <% @event.defaulters.each do |registrant| %>
        <div class="list-group-item"><%= registrant.display_name %> <span class="text-muted small"><%= registrant.email %></span></div>
      <% end %>
      <% if @event.defaulters.empty? %>
        <div class="list-group-item text-muted text-center py-3">Everyone attended, or no registrants yet.</div>
      <% end %>
    </div>
  </div>
<% end %>
