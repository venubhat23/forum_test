<% content_for :title, "Create Event" %>

<div class="page-header">
  <h1 class="page-title h4">Create Event</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", event: @event, url: forum_events_path(forum_slug: @current_forum.slug), method: :post %>
      </div>
    </div>
  </div>
</div>
