<% content_for :title, "Edit Event" %>

<div class="page-header">
  <h1 class="page-title h4">Edit Event</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", event: @event, url: forum_event_path(forum_slug: @current_forum.slug, id: @event.id), method: :patch %>
      </div>
    </div>
  </div>
</div>
