<% content_for :title, "Forum Settings" %>

<div class="page-header">
  <h1 class="page-title h4">Forum Settings</h1>
  <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @setting, url: forum_settings_path(forum_slug: @current_forum.slug), method: :patch, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :logo, class: "form-label" %>
            <%= f.file_field :logo, class: "form-control", accept: "image/*" %>
            <% if @setting.logo.attached? %>
              <div class="text-muted small mt-1">Current: <%= @setting.logo.filename %></div>
            <% end %>
          </div>
          <div class="mb-3">
            <%= f.label :theme_color, class: "form-label" %>
            <%= f.color_field :theme_color, class: "form-control form-control-color" %>
          </div>
          <div class="mb-3">
            <%= f.label :invoice_prefix, class: "form-label" %>
            <%= f.text_field :invoice_prefix, class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :attendance_rules, class: "form-label" %>
            <%= f.text_area :attendance_rules, class: "form-control", rows: 2 %>
          </div>
          <div class="mb-3">
            <%= f.label :meeting_rules, class: "form-label" %>
            <%= f.text_area :meeting_rules, class: "form-control", rows: 2 %>
          </div>
          <div class="mb-4">
            <%= f.label :membership_rules, class: "form-label" %>
            <%= f.text_area :membership_rules, class: "form-control", rows: 2 %>
          </div>
          <%= f.submit "Save Settings", class: "btn btn-primary btn-lg" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
