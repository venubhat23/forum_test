<% persisted = @invoice.persisted? %>

<div class="card invoice-form-card mb-4">
  <div class="invoice-preview-topbar"></div>
  <div class="card-body p-4">
    <%= form_with model: @invoice,
          url: (persisted ? forum_invoice_path(forum_slug: @current_forum.slug, id: @invoice) : forum_invoices_path(forum_slug: @current_forum.slug)),
          method: (persisted ? :patch : :post),
          local: true do |f| %>

      <div class="mb-4">
        <div class="text-uppercase text-muted small fw-semibold mb-2"><i class="bi bi-person me-1"></i> Member</div>
        <% if persisted %>
          <div class="form-control-plaintext fw-semibold"><%= @invoice.user.display_name %></div>
        <% else %>
          <%= f.select :user_id, @members.map { |m| [ "#{m.display_name} (#{m.chapter&.name})", m.id ] },
                { include_blank: "Select member" }, class: "form-select", required: true %>
        <% end %>
      </div>

      <div class="mb-4">
        <div class="text-uppercase text-muted small fw-semibold mb-2"><i class="bi bi-cash-coin me-1"></i> Amount &amp; Due Date</div>
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <%= f.label :amount, "Amount (INR)", class: "form-label" %>
            <%= f.number_field :amount, class: "form-control", step: "0.01", min: 0, required: true %>
          </div>
          <div class="col-12 col-md-6">
            <%= f.label :due_date, class: "form-label" %>
            <%= f.date_field :due_date, class: "form-control", required: true %>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <div class="text-uppercase text-muted small fw-semibold mb-2"><i class="bi bi-card-text me-1"></i> Description</div>
        <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "e.g. Annual membership renewal — 2026" %>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <%= f.submit (persisted ? "Update Invoice" : "Create Invoice"), class: "btn btn-primary btn-lg" %>
        <%= link_to "Cancel", (persisted ? forum_invoice_path(forum_slug: @current_forum.slug, id: @invoice) : forum_invoices_path(forum_slug: @current_forum.slug)), class: "btn btn-outline-secondary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>
