<%= form_with model: schedule, url: forum_chapter_meeting_schedules_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :post, local: true,
      data: { controller: "submit-loading", action: "submit->submit-loading#start" } do |f| %>
  <% if schedule.errors.any? %>
    <div class="alert alert-danger"><%= schedule.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Schedule Title (optional)", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "e.g. Weekly Chapter Meeting" %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-4">
      <%= f.label :day_of_week, "Recurring Day", class: "form-label" %>
      <%= f.select :day_of_week, MeetingSchedule::DAY_NAMES.each_with_index.map { |name, i| [ name, i ] }, {}, class: "form-select", required: true %>
    </div>
    <div class="col-12 col-sm-4">
      <%= f.label :start_time, "From", class: "form-label" %>
      <%= f.time_field :start_time, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-sm-4">
      <%= f.label :end_time, "To", class: "form-label" %>
      <%= f.time_field :end_time, class: "form-control", required: true %>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :start_date, "Start Date", class: "form-label" %>
      <%= f.date_field :start_date, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :end_date, "End Date", class: "form-label" %>
      <%= f.date_field :end_date, class: "form-control", required: true %>
      <div class="form-text">Schedule between <%= MeetingSchedule::MIN_MONTHS %> and <%= MeetingSchedule::MAX_MONTHS %> months from the start date.</div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :venue, class: "form-label" %>
    <%= f.text_field :venue, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :agenda, class: "form-label" %>
    <%= f.text_area :agenda, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-4">
    <%= f.label :notes, "Other Requirements (optional)", class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 2, placeholder: "Anything attendees or the chapter admin should know" %>
  </div>

  <h2 class="h6 text-uppercase text-muted mb-3">Attendees</h2>
  <div class="mb-4" data-controller="member-picker">
    <div class="d-flex flex-wrap gap-2 mb-2">
      <button type="button" class="btn btn-sm btn-outline-primary" data-action="member-picker#selectAll">Select All</button>
      <button type="button" class="btn btn-sm btn-outline-danger" data-action="member-picker#clearAll">Clear</button>
    </div>
    <%= f.select :attendee_ids, candidates.map { |u| [ u.display_name, u.id ] }, { selected: schedule.attendee_ids }, multiple: true, class: "form-select", size: 8, data: { "member-picker-target": "select" } %>
    <div class="form-text">Hold Ctrl/Cmd to select individual people, or use the buttons above.</div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <button type="submit" class="btn btn-primary btn-lg" data-submit-loading-target="button" data-loading-text="Creating schedule...">
      <span data-submit-loading-target="spinner" class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true"></span>
      <span data-submit-loading-target="label">Create Schedule</span>
    </button>
    <%= link_to "Cancel", forum_chapter_meeting_schedules_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
