<% content_for :title, "Weekly Presentations · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Weekly Presentations</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %></p>
  </div>
  <% if can? :create, WeeklyPresentation %>
    <%= link_to new_forum_chapter_weekly_presentation_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Schedule Presentation
    <% end %>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Presentations</div>
        <div class="mini-stat-value text-primary"><%= @total_presentations %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-easel"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_chapter_weekly_presentations_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by member or topic...", style: "max-width: 280px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_weekly_presentations_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Member</th>
          <th>Topic</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @presentations.each do |p| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= p.member.display_name.first.upcase %></span>
                <span class="fw-semibold"><%= p.member.display_name %></span>
              </div>
            </td>
            <td><%= p.topic %></td>
            <td><%= p.scheduled_on.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to forum_chapter_weekly_presentation_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: p.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @presentations.empty? %>
          <tr><td colspan="4" class="text-center text-muted py-4">No presentations scheduled yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @presentations %>
