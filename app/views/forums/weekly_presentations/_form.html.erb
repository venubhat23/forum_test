<%= form_with model: presentation, url: url, method: method, local: true do |f| %>
  <div class="row g-3 mb-3">
    <div class="col-12 col-sm-6">
      <%= f.label :member_id, "Member", class: "form-label" %>
      <%= f.collection_select :member_id, @chapter.members.order(:full_name), :id, :display_name, { include_blank: true }, class: "form-select", required: true %>
    </div>
    <div class="col-12 col-sm-6">
      <%= f.label :scheduled_on, class: "form-label" %>
      <%= f.date_field :scheduled_on, class: "form-control", required: true %>
    </div>
  </div>
  <div class="mb-3">
    <%= f.label :topic, class: "form-label" %>
    <%= f.text_field :topic, class: "form-control", required: true %>
  </div>
  <div class="mb-3">
    <%= f.label :meeting_id, "Meeting (optional)", class: "form-label" %>
    <%= f.collection_select :meeting_id, @chapter.meetings.order(scheduled_at: :desc), :id, ->(m) { "#{m.meeting_type.titleize} - #{m.scheduled_at.strftime('%d %b %Y')}" }, { include_blank: true }, class: "form-select" %>
  </div>
  <div class="mb-3">
    <%= f.label :deck, "Slide Deck", class: "form-label" %>
    <%= f.file_field :deck, class: "form-control" %>
  </div>
  <div class="mb-4">
    <%= f.label :feedback, class: "form-label" %>
    <%= f.text_area :feedback, class: "form-control", rows: 3 %>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancel", forum_chapter_weekly_presentations_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
