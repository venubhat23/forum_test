<% content_for :title, "New Business Category" %>

<div class="page-header">
  <h1 class="page-title h4"><%= @category.parent_id? ? "New Speciality" : "New Business Category" %></h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-body p-4">
        <%= render "form", category: @category, url: forum_business_categories_path(forum_slug: @current_forum.slug), method: :post %>
      </div>
    </div>
  </div>
</div>
