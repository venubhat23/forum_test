<% content_for :title, "Business Categories" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Business Categories</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, BusinessCategory %>
    <%= link_to new_forum_business_category_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> New Category
    <% end %>
  <% end %>
</div>

<div class="row g-3">
  <% @top_level.each do |category| %>
    <div class="col-12 col-lg-6">
      <div class="card h-100">
        <div class="card-header d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center gap-2">
            <span class="row-avatar"><i class="bi bi-tags"></i></span>
            <span class="fw-semibold"><%= category.name %></span>
          </div>
          <div class="d-flex gap-1">
            <% if can? :create, BusinessCategory %>
              <%= link_to new_forum_business_category_path(forum_slug: @current_forum.slug, parent_id: category.id), class: "icon-btn icon-btn-view", title: "Add Speciality" do %>
                <i class="bi bi-plus-lg"></i>
              <% end %>
            <% end %>
            <% if can? :update, category %>
              <%= link_to edit_forum_business_category_path(forum_slug: @current_forum.slug, id: category.id), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to forum_business_category_path(forum_slug: @current_forum.slug, id: category.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                    data: { turbo_confirm: "Delete #{category.name} and all its specialities?" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>
        </div>
        <div class="list-group list-group-flush">
          <% category.children.each do |child| %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <span><%= child.name %></span>
              <% if can? :update, child %>
                <div class="d-flex gap-1">
                  <%= link_to edit_forum_business_category_path(forum_slug: @current_forum.slug, id: child.id), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to forum_business_category_path(forum_slug: @current_forum.slug, id: child.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                        data: { turbo_confirm: "Delete #{child.name}?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
          <% if category.children.empty? %>
            <div class="list-group-item text-muted small">No specialities yet.</div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @top_level.empty? %>
    <div class="col-12">
      <div class="card"><div class="card-body text-center text-muted py-4">No business categories yet. Create the first one to get started.</div></div>
    </div>
  <% end %>
</div>
