<% content_for :title, "Referrals · #{@chapter.name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Referrals</h1>
    <p class="page-subtitle mb-0"><%= @chapter.name %> &middot; <%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_chapter_referral_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Give Referral
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total</div>
        <div class="mini-stat-value text-primary"><%= @total_referrals %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-arrow-left-right"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Pending</div>
        <div class="mini-stat-value text-warning"><%= @pending_referrals %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Accepted</div>
        <div class="mini-stat-value text-success"><%= @accepted_referrals %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Converted</div>
        <div class="mini-stat-value text-info"><%= @converted_referrals %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-trophy"></i></div>
    </div>
  </div>
</div>

<div class="card mb-3">
  <div class="card-header fw-semibold">Referrals per Month (last 6 months)</div>
  <div class="card-body d-flex flex-wrap gap-4">
    <% @monthly_stats.each do |month, count| %>
      <div class="text-center">
        <div class="fw-bold h5 mb-0"><%= count %></div>
        <div class="text-muted small"><%= month.strftime("%b %Y") %></div>
      </div>
    <% end %>
  </div>
</div>

<%= form_with url: forum_chapter_referrals_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by prospect name...", style: "max-width: 260px;" %>
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ] ] + Referral.statuses.keys.map { |s| [ s.titleize, s ] }, params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_chapter_referrals_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Prospect</th>
          <th>Given By</th>
          <th>Given To</th>
          <th>Type</th>
          <th>Status</th>
          <th>Thanksgivings</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @referrals.each do |referral| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= referral.prospect_name.first.upcase %></span>
                <span class="fw-semibold"><%= referral.prospect_name %></span>
              </div>
            </td>
            <td><%= referral.giver.display_name %></td>
            <td><%= referral.receiver.display_name %></td>
            <td><span class="badge bg-secondary"><%= referral.referral_type.titleize %></span></td>
            <td><span class="badge bg-secondary"><%= referral.status.titleize %></span></td>
            <td><%= referral.thanksgiving_slips.size %></td>
            <td><%= referral.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to forum_chapter_referral_path(forum_slug: @current_forum.slug, chapter_id: @chapter.id, id: referral.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @referrals.empty? %>
          <tr><td colspan="8" class="text-center text-muted py-4">No referrals yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @referrals %>
