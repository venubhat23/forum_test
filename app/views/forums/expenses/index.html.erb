<% content_for :title, "Expenses" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Expenses</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_expense_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> Record Expense
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Expenses</div>
        <div class="mini-stat-value text-primary"><%= @total_expenses %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-receipt"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-6">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total Amount</div>
        <div class="mini-stat-value text-danger">&#8377;<%= number_with_delimiter(@total_amount.to_i) %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-danger"><i class="bi bi-cash-stack"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_expenses_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by category...", style: "max-width: 260px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_expenses_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Category</th>
          <th>Amount</th>
          <th>Date</th>
          <th>Notes</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @expenses.each do |expense| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-receipt"></i></span>
                <span class="fw-semibold"><%= expense.category %></span>
              </div>
            </td>
            <td>&#8377;<%= number_with_delimiter(expense.amount.to_i) %></td>
            <td><%= expense.incurred_on.strftime("%d %b %Y") %></td>
            <td><%= expense.notes %></td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <%= link_to edit_forum_expense_path(forum_slug: @current_forum.slug, id: expense.id), class: "icon-btn icon-btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to forum_expense_path(forum_slug: @current_forum.slug, id: expense.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                      data: { turbo_confirm: "Delete this expense?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @expenses.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No expenses recorded yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @expenses %>
