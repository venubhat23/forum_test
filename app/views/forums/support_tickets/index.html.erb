<% content_for :title, "Support" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Support</h1>
    <p class="page-subtitle mb-0">Your support tickets.</p>
  </div>
  <%= link_to new_forum_support_ticket_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> New Ticket
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total</div>
        <div class="mini-stat-value text-primary"><%= @total_tickets %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-headset"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Open</div>
        <div class="mini-stat-value text-warning"><%= @open_tickets %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Closed</div>
        <div class="mini-stat-value text-success"><%= @closed_tickets %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_support_tickets_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ] ] + SupportTicket.statuses.keys.map { |s| [ s.titleize, s ] }, params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_support_tickets_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Subject</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead>
      <tbody>
        <% @tickets.each do |ticket| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-headset"></i></span>
                <span class="fw-semibold"><%= ticket.subject %></span>
              </div>
            </td>
            <td><%= ticket.priority.titleize %></td>
            <td><span class="badge bg-secondary"><%= ticket.status.titleize %></span></td>
            <td><%= ticket.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to forum_support_ticket_path(forum_slug: @current_forum.slug, id: ticket.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @tickets.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No tickets yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
