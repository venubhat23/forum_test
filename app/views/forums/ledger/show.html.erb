<% content_for :title, "Ledger" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Ledger</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %> &middot; every rupee in and out, end to end</p>
  </div>
  <%= link_to forum_finance_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-cash-stack me-1"></i> Finance Overview
  <% end %>
</div>

<%= form_with url: forum_ledger_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap align-items-end gap-2">
    <div>
      <label class="form-label small mb-1">From</label>
      <%= date_field_tag :from, @from, class: "form-control" %>
    </div>
    <div>
      <label class="form-label small mb-1">To</label>
      <%= date_field_tag :to, @to, class: "form-control" %>
    </div>
    <%= submit_tag "Apply", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_ledger_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-indigo"><i class="bi bi-wallet2"></i></div>
      <div>
        <div class="stats-value">&#8377;<%= number_with_delimiter(@opening_balance.to_i) %></div>
        <div class="stats-label">Opening Balance</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-green"><i class="bi bi-arrow-down-circle"></i></div>
      <div>
        <div class="stats-value text-success">+&#8377;<%= number_with_delimiter(@total_credits.to_i) %></div>
        <div class="stats-label">Collected (Credits)</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-red"><i class="bi bi-arrow-up-circle"></i></div>
      <div>
        <div class="stats-value text-danger">-&#8377;<%= number_with_delimiter(@total_debits.to_i) %></div>
        <div class="stats-label">Spent (Debits)</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stats-card">
      <div class="icon-bg gradient-blue"><i class="bi bi-piggy-bank"></i></div>
      <div>
        <div class="stats-value <%= @closing_balance.negative? ? 'text-danger' : 'text-success' %>">&#8377;<%= number_with_delimiter(@closing_balance.to_i) %></div>
        <div class="stats-label">Closing Balance &middot; Money Left</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header fw-semibold">Transactions &middot; <%= @from.strftime("%d %b %Y") %> to <%= @to.strftime("%d %b %Y") %></div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Date</th>
          <th>Description</th>
          <th>Party</th>
          <th class="text-end">Credit (+)</th>
          <th class="text-end">Debit (-)</th>
          <th class="text-end">Balance</th>
        </tr>
      </thead>
      <tbody>
        <tr class="table-light">
          <td colspan="5" class="fw-semibold">Opening Balance</td>
          <td class="text-end fw-semibold">&#8377;<%= number_with_delimiter(@opening_balance.to_i) %></td>
        </tr>
        <% @entries.each do |entry| %>
          <tr>
            <td><%= entry[:date].strftime("%d %b %Y") %></td>
            <td><%= entry[:description] %></td>
            <td><%= entry[:party] %></td>
            <td class="text-end text-success">
              <%= entry[:kind] == :credit ? "+&#8377;#{number_with_delimiter(entry[:amount].to_i)}".html_safe : "" %>
            </td>
            <td class="text-end text-danger">
              <%= entry[:kind] == :debit ? "-&#8377;#{number_with_delimiter(entry[:amount].to_i)}".html_safe : "" %>
            </td>
            <td class="text-end fw-semibold">&#8377;<%= number_with_delimiter(entry[:balance].to_i) %></td>
          </tr>
        <% end %>
        <% if @entries.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No transactions in this period.</td></tr>
        <% end %>
        <tr class="table-light">
          <td colspan="5" class="fw-semibold">Closing Balance</td>
          <td class="text-end fw-semibold <%= @closing_balance.negative? ? 'text-danger' : 'text-success' %>">&#8377;<%= number_with_delimiter(@closing_balance.to_i) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
