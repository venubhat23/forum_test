<% content_for :title, "New Announcement" %>

<div class="page-header">
  <h1 class="page-title h4">New Announcement</h1>
  <p class="page-subtitle mb-0">Posted to <%= @current_forum.name %> only.</p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @announcement, url: forum_announcements_path(forum_slug: @current_forum.slug), method: :post, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :title, class: "form-label" %>
            <%= f.text_field :title, class: "form-control", required: true %>
          </div>
          <div class="mb-4">
            <%= f.label :body, class: "form-label" %>
            <%= f.text_area :body, class: "form-control", rows: 4, required: true %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Post Announcement", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_announcements_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
