<% content_for :title, "Announcements" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Announcements</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <%= link_to new_forum_announcement_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
    <i class="bi bi-plus-lg me-1"></i> New Announcement
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total</div>
        <div class="mini-stat-value text-primary"><%= @total_announcements %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-megaphone"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">This Forum</div>
        <div class="mini-stat-value text-info"><%= @forum_announcements %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-building"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-4">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Platform-wide</div>
        <div class="mini-stat-value text-success"><%= @platform_announcements %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-globe"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_announcements_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by title...", style: "max-width: 260px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_announcements_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Scope</th>
          <th>Posted</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @announcements.each do |a| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><i class="bi bi-megaphone"></i></span>
                <span class="fw-semibold"><%= a.title %></span>
              </div>
            </td>
            <td><span class="badge bg-secondary"><%= a.everyone? ? "Platform-wide" : "This forum" %></span></td>
            <td><%= a.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <% if a.forum_id == @current_forum.id %>
                <%= button_to forum_announcement_path(forum_slug: @current_forum.slug, id: a.id), method: :delete, class: "icon-btn icon-btn-danger", title: "Delete",
                      data: { turbo_confirm: "Delete this announcement?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @announcements.empty? %>
          <tr><td colspan="4" class="text-center text-muted py-4">No announcements yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
