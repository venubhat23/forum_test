<% content_for :title, "Office Darshan · #{@darshan.member.display_name}" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4"><%= @darshan.member.display_name %></h1>
    <p class="page-subtitle mb-0"><%= @darshan.visit_date.strftime("%d %b %Y") %> &middot; <span class="badge bg-secondary"><%= @darshan.status.titleize %></span></p>
  </div>
  <% if can? :destroy, @darshan %>
    <%= button_to "Delete", forum_office_darshan_path(forum_slug: @current_forum.slug, id: @darshan.id), method: :delete, class: "btn btn-outline-danger",
          data: { turbo_confirm: "Delete this visit record?" } %>
  <% end %>
</div>

<% if @darshan.photos.attached? %>
  <div class="card mb-4">
    <div class="card-header fw-semibold">Photos</div>
    <div class="card-body d-flex flex-wrap gap-2">
      <% @darshan.photos.each do |photo| %>
        <%= link_to photo.filename, rails_blob_path(photo, disposition: "attachment") %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @darshan.notes.present? %>
  <div class="card">
    <div class="card-header fw-semibold">Notes</div>
    <div class="card-body"><%= simple_format(@darshan.notes) %></div>
  </div>
<% end %>
