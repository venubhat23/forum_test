<% content_for :title, "Office Darshan" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Office Darshan</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, OfficeDarshan %>
    <%= link_to new_forum_office_darshan_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Invite to Office Darshan
    <% end %>
  <% end %>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Total</div>
        <div class="mini-stat-value text-primary"><%= @total_darshans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-primary"><i class="bi bi-building-check"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Invited</div>
        <div class="mini-stat-value text-warning"><%= @invited_darshans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-warning"><i class="bi bi-hourglass-split"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Accepted</div>
        <div class="mini-stat-value text-info"><%= @accepted_darshans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-info"><i class="bi bi-check2"></i></div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="mini-stat-card">
      <div>
        <div class="mini-stat-label">Completed</div>
        <div class="mini-stat-value text-success"><%= @completed_darshans %></div>
      </div>
      <div class="mini-stat-icon mini-stat-icon-success"><i class="bi bi-check-circle"></i></div>
    </div>
  </div>
</div>

<%= form_with url: forum_office_darshans_path(forum_slug: @current_forum.slug), method: :get, local: true, class: "card mb-3" do %>
  <div class="card-body d-flex flex-wrap gap-2">
    <%= select_tag :status, options_for_select([ [ "All statuses", "" ] ] + OfficeDarshan.statuses.keys.map { |s| [ s.titleize, s ] }, params[:status]), class: "form-select", style: "max-width: 200px;" %>
    <%= submit_tag "Filter", class: "btn btn-outline-secondary" %>
    <%= link_to "Reset", forum_office_darshans_path(forum_slug: @current_forum.slug), class: "btn btn-link" %>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Host</th>
          <th>Visitor</th>
          <th>Scheduled</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @darshans.each do |d| %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="row-avatar"><%= d.host.display_name.first.upcase %></span>
                <span class="fw-semibold"><%= d.host.display_name %></span>
              </div>
            </td>
            <td><%= d.visitor.display_name %></td>
            <td><%= d.scheduled_at.strftime("%d %b %Y %H:%M") %></td>
            <td><span class="badge bg-secondary"><%= d.status.titleize %></span></td>
            <td class="text-end">
              <%= link_to forum_office_darshan_path(forum_slug: @current_forum.slug, id: d.id), class: "icon-btn icon-btn-view", title: "View" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @darshans.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No office darshan visits yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
