<% content_for :title, "Office Darshan Invite" %>

<div class="page-header">
  <h1 class="page-title h4">Invite to Office Darshan</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @darshan, url: forum_office_darshans_path(forum_slug: @current_forum.slug), method: :post, local: true do |f| %>
          <% if current_user.forum_admin? || current_user.chapter_admin? %>
            <div class="mb-3">
              <%= f.label :host_id, "Host", class: "form-label" %>
              <%= f.collection_select :host_id, @current_forum.users.where(role: [ :member, :committee_member ]).order(:full_name), :id, :display_name, {}, class: "form-select", required: true %>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :visitor_id, "Invite Member", class: "form-label" %>
            <%= f.collection_select :visitor_id, @current_forum.users.where(role: [ :member, :committee_member ]).order(:full_name), :id, :display_name, { include_blank: true }, class: "form-select", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :scheduled_at, "Proposed Date & Time", class: "form-label" %>
            <%= f.datetime_field :scheduled_at, class: "form-control", required: true %>
          </div>
          <% if current_user.forum_admin? || current_user.chapter_admin? %>
            <div class="mb-3">
              <%= f.label :status, class: "form-label" %>
              <%= f.select :status, OfficeDarshan.statuses.keys.map { |s| [ s.titleize, s ] }, {}, class: "form-select" %>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :photos, class: "form-label" %>
            <%= f.file_field :photos, multiple: true, class: "form-control", accept: "image/*" %>
          </div>
          <div class="mb-4">
            <%= f.label :notes, class: "form-label" %>
            <%= f.text_area :notes, class: "form-control", rows: 3 %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Send Invite", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_office_darshans_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
