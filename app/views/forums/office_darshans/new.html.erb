<% content_for :title, "Schedule Office Darshan" %>

<div class="page-header">
  <h1 class="page-title h4">Schedule Office Darshan Visit</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @darshan, url: forum_office_darshans_path(forum_slug: @current_forum.slug), method: :post, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :member_id, "Member", class: "form-label" %>
            <%= f.collection_select :member_id, @current_forum.users.member.order(:full_name), :id, :display_name, { include_blank: true }, class: "form-select", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :visit_date, class: "form-label" %>
            <%= f.date_field :visit_date, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :photos, class: "form-label" %>
            <%= f.file_field :photos, multiple: true, class: "form-control", accept: "image/*" %>
          </div>
          <div class="mb-4">
            <%= f.label :notes, class: "form-label" %>
            <%= f.text_area :notes, class: "form-control", rows: 3 %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Schedule Visit", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_office_darshans_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
