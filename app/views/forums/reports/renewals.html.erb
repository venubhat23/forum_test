<% content_for :title, "Renewals Report" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <h1 class="page-title h4">Renewals Report</h1>
  <%= link_to "Export CSV", "#{renewals_forum_reports_path}.csv", class: "btn btn-outline-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Name</th><th>Email</th><th>Renews On</th><th>Status</th></tr></thead>
      <tbody>
        <% @renewals.each do |u| %>
          <tr>
            <td class="fw-semibold"><%= u.display_name %></td>
            <td><%= u.email %></td>
            <td><%= u.renews_on.strftime("%d %b %Y") %></td>
            <td><%= u.membership_status.titleize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
