<% content_for :title, "Events Report" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <h1 class="page-title h4">Events Report</h1>
  <%= link_to "Export CSV", "#{events_forum_reports_path}.csv", class: "btn btn-outline-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Title</th><th>Type</th><th>Date</th><th>Registrants</th></tr></thead>
      <tbody>
        <% @events.each do |e| %>
          <tr>
            <td class="fw-semibold"><%= e.title %></td>
            <td><%= e.event_type.titleize %></td>
            <td><%= e.starts_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= e.event_registrations.size %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
