<% content_for :title, "Meetings Report" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <h1 class="page-title h4">Meetings Report</h1>
  <%= link_to "Export CSV", "#{meetings_forum_reports_path}.csv", class: "btn btn-outline-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Chapter</th><th>Type</th><th>Date</th><th>Attendance %</th></tr></thead>
      <tbody>
        <% @meetings.each do |m| %>
          <tr>
            <td class="fw-semibold"><%= m.chapter.name %></td>
            <td><%= m.meeting_type.titleize %></td>
            <td><%= m.scheduled_at.strftime("%d %b %Y %H:%M") %></td>
            <td><%= m.attendance_percentage %>%</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
