<% content_for :title, "Referrals Report" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <h1 class="page-title h4">Referrals Report</h1>
  <%= link_to "Export CSV", "#{referrals_forum_reports_path}.csv", class: "btn btn-outline-primary" %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Giver</th><th>Receiver</th><th>Prospect</th><th>Type</th><th>Status</th><th>Date</th></tr></thead>
      <tbody>
        <% @referrals.each do |r| %>
          <tr>
            <td class="fw-semibold"><%= r.giver.display_name %></td>
            <td><%= r.receiver.display_name %></td>
            <td><%= r.prospect_name %></td>
            <td><%= r.referral_type.titleize %></td>
            <td><%= r.status.titleize %></td>
            <td><%= r.created_at.strftime("%d %b %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
