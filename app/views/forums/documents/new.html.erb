<% content_for :title, "Upload Document" %>

<div class="page-header">
  <h1 class="page-title h4">Upload Document</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-6">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @document, url: forum_documents_path(forum_slug: @current_forum.slug), method: :post, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :title, class: "form-label" %>
            <%= f.text_field :title, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :category, class: "form-label" %>
            <%= f.text_field :category, class: "form-control" %>
          </div>
          <div class="mb-4">
            <%= f.label :file, class: "form-label" %>
            <%= f.file_field :file, class: "form-control", required: true %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Upload", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_documents_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
