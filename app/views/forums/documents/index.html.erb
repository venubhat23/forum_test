<% content_for :title, "Documents" %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="page-title h4">Documents</h1>
    <p class="page-subtitle mb-0"><%= @current_forum.name %></p>
  </div>
  <% if can? :create, Document %>
    <%= link_to new_forum_document_path(forum_slug: @current_forum.slug), class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Upload Document
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>File</th>
          <th>Uploaded</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |doc| %>
          <tr>
            <td class="fw-semibold"><%= doc.title %></td>
            <td><%= doc.category %></td>
            <td><%= doc.file.attached? ? link_to(doc.file.filename, rails_blob_path(doc.file, disposition: "attachment")) : "—" %></td>
            <td><%= doc.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <% if can? :destroy, doc %>
                <%= button_to "Delete", forum_document_path(forum_slug: @current_forum.slug, id: doc.id), method: :delete, class: "btn btn-sm btn-outline-danger",
                      data: { turbo_confirm: "Delete #{doc.title}?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @documents.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4">No documents yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @documents %>
