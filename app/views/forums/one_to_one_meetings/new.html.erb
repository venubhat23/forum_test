<% content_for :title, "Request One-to-One Meeting" %>

<div class="page-header">
  <h1 class="page-title h4">Request a One-to-One Meeting</h1>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <%= form_with model: @meeting, url: forum_one_to_one_meetings_path(forum_slug: @current_forum.slug), method: :post, local: true do |f| %>
          <% if current_user.forum_admin? || current_user.chapter_admin? %>
            <div class="mb-3">
              <%= f.label :requester_id, "Requester", class: "form-label" %>
              <%= f.collection_select :requester_id, @current_forum.users.where(role: [ :member, :committee_member ]).order(:full_name), :id, :display_name, {}, class: "form-select", required: true %>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :requested_with_id, "Meet With", class: "form-label" %>
            <%= f.collection_select :requested_with_id, @current_forum.users.where(role: [ :member, :committee_member ]).order(:full_name), :id, :display_name, { include_blank: true }, class: "form-select", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :scheduled_at, "Date & Time", class: "form-label" %>
            <%= f.datetime_field :scheduled_at, class: "form-control", required: true %>
          </div>
          <div class="mb-4">
            <%= f.label :notes, class: "form-label" %>
            <%= f.text_area :notes, class: "form-control", rows: 3 %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Request Meeting", class: "btn btn-primary btn-lg" %>
            <%= link_to "Cancel", forum_one_to_one_meetings_path(forum_slug: @current_forum.slug), class: "btn btn-outline-secondary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
