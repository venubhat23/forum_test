<% content_for :title, "Help & Support" %>

<div class="page-header">
  <h1 class="page-title h4">Help &amp; Support</h1>
</div>

<div class="card mb-4">
  <div class="card-header fw-semibold">Frequently Asked Questions</div>
  <div class="accordion accordion-flush" id="faqAccordion">
    <% @faq.each_with_index do |item, i| %>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq<%= i %>">
            <%= item[:q] %>
          </button>
        </h2>
        <div id="faq<%= i %>" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
          <div class="accordion-body"><%= item[:a] %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <div class="fw-semibold">Still need help?</div>
      <div class="text-muted small">Raise a support ticket and our team will follow up.</div>
    </div>
    <%= link_to "Raise a Ticket", new_forum_support_ticket_path(forum_slug: @current_forum.slug), class: "btn btn-primary" %>
  </div>
</div>
